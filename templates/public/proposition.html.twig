{% extends 'base.html.twig' %}

{% block title %}Proposition commerciale — TDBR{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto px-4 py-12">

    {% if proposition.statut == 'payee' %}
        {# Payée #}
        <div class="card p-8 text-center">
            <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
            </div>
            <h1 class="font-heading text-2xl font-bold mb-2">Paiement confirmé</h1>
            <p class="text-gray-600 mb-6">Merci ! Votre paiement a bien été reçu. Vous recevrez une confirmation par email.</p>
            <a href="{{ path('proposition_facture', {token: proposition.token}) }}"
               class="btn-outline inline-flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                Télécharger la facture
            </a>
        </div>

    {% elseif proposition.statut == 'acceptee' and proposition.commande %}
        {# Acceptée mais paiement non finalisé → rediriger vers paiement #}
        <div class="card p-8 text-center">
            <h1 class="font-heading text-2xl font-bold mb-3">Paiement en cours</h1>
            <p class="text-gray-600 mb-6">Votre proposition a été validée. Finalisez le paiement pour confirmer votre commande.</p>
            <a href="{{ path('proposition_pay', {token: proposition.token}) }}" class="btn-primary text-lg px-8 py-3">
                Procéder au paiement
            </a>
        </div>

    {% else %}
        {# Affichage de la proposition #}
        <div class="mb-8 text-center">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-accent rounded-full mb-4">
                <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
            </div>
            <h1 class="font-heading text-3xl font-black text-dark">Proposition commerciale</h1>
            {% if proposition.clientNom %}
                <p class="text-gray-500 mt-1">À l'attention de {{ proposition.clientNom }}</p>
            {% endif %}
            <p class="text-gray-400 text-sm mt-1">Émise le {{ proposition.createdAt|date('d/m/Y') }}</p>
        </div>

        <div class="card p-8 space-y-6">

            {# Description #}
            <div>
                <h2 class="font-heading text-xl font-bold mb-3 text-dark">Détail de la proposition</h2>
                <div class="text-gray-700 leading-relaxed whitespace-pre-line bg-gray-50 rounded-lg p-4">{{ proposition.description }}</div>
            </div>

            {# Prix - détail des 4 lignes #}
            <div class="border-t pt-6 space-y-2">
                {% if proposition.coutDesign is not null and proposition.coutDesign > 0 %}
                <div class="flex justify-between text-sm text-gray-600">
                    <span>Création du design et adaptation aux supports</span>
                    <span class="font-medium">{{ proposition.coutDesign|number_format(2, ',', ' ') }} €</span>
                </div>
                {% endif %}
                <div class="flex justify-between text-sm text-gray-600">
                    <span>Prix public</span>
                    <span class="font-medium">{{ proposition.prixPublic|number_format(2, ',', ' ') }} €</span>
                </div>
                {% if proposition.fraisManutention is not null and proposition.fraisManutention > 0 %}
                <div class="flex justify-between text-sm text-gray-600">
                    <span>Frais de manutention</span>
                    <span class="font-medium">{{ proposition.fraisManutention|number_format(2, ',', ' ') }} €</span>
                </div>
                {% endif %}
                {% if proposition.ristourne is not null and proposition.ristourne > 0 %}
                <div class="flex justify-between text-sm text-green-700">
                    <span>Ristourne</span>
                    <span class="font-medium">− {{ proposition.ristourne|number_format(2, ',', ' ') }} €</span>
                </div>
                {% endif %}
                <div class="flex items-baseline justify-between border-t pt-3 mt-2">
                    <span class="text-gray-700 font-semibold">Total TTC</span>
                    <span class="font-heading text-3xl font-black text-primary">
                        {{ proposition.prixTotal|number_format(2, ',', ' ') }} €
                    </span>
                </div>
                <p class="text-xs text-gray-400 text-right">TVA non applicable – art. 293 B du CGI</p>
            </div>

            {# Bouton valider #}
            <div class="border-t pt-6">
                <form method="post" action="{{ path('proposition_accept', {token: proposition.token}) }}">
                    <button type="submit"
                            class="w-full btn-primary text-lg py-4 rounded-xl font-bold">
                        Valider et payer
                    </button>
                </form>
                <p class="text-center text-xs text-gray-400 mt-3">
                    Vous serez redirigé vers la page de paiement sécurisé Stripe.
                </p>
            </div>

        </div>

        <p class="text-center text-sm text-gray-400 mt-6">
            Une question ? <a href="{{ path('contact') }}?sujet=À propos de la proposition commerciale {{ proposition.token|slice(0,12)|upper }}" class="text-primary hover:underline">Contactez-nous</a>
        </p>

    {% endif %}

</div>
{% endblock %}
