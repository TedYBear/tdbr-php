{% extends 'admin/base_admin.html.twig' %}

{% block title %}Utilisateurs{% endblock %}
{% block page_title %}Utilisateurs{% endblock %}

{% block body %}
    <div class="mb-6 flex items-center justify-between">
        <p class="text-gray-500 text-sm">{{ total }} utilisateur{{ total > 1 ? 's' : '' }} enregistré{{ total > 1 ? 's' : '' }}</p>
    </div>

    <div class="card overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b">
                <tr>
                    <th class="text-left px-4 py-3 font-semibold text-gray-600">Nom</th>
                    <th class="text-left px-4 py-3 font-semibold text-gray-600">Email</th>
                    <th class="text-left px-4 py-3 font-semibold text-gray-600">Téléphone</th>
                    <th class="text-left px-4 py-3 font-semibold text-gray-600">Rôle</th>
                    <th class="text-center px-4 py-3 font-semibold text-gray-600">Commandes</th>
                    <th class="text-left px-4 py-3 font-semibold text-gray-600">Inscrit le</th>
                    <th class="text-right px-4 py-3 font-semibold text-gray-600">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                {% set me = app.user %}
                {% for row in rows %}
                    {% set user = row[0] %}
                    {% set commandeCount = row.commandeCount %}
                    {% set isSelf = (me and me.id == user.id) %}
                    <tr class="hover:bg-gray-50 transition">
                        <td class="px-4 py-3">
                            <div class="font-semibold text-gray-800">
                                {{ user.prenom }} {{ user.nom }}
                                {% if isSelf %}<span class="ml-1 text-xs text-gray-400">(vous)</span>{% endif %}
                            </div>
                        </td>
                        <td class="px-4 py-3 text-gray-600">
                            <a href="mailto:{{ user.email }}" class="hover:text-primary transition">
                                {{ user.email }}
                            </a>
                        </td>
                        <td class="px-4 py-3 text-gray-500">
                            {{ user.telephone ?? '—' }}
                        </td>
                        <td class="px-4 py-3">
                            {% if 'ROLE_ADMIN' in user.roles %}
                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-red-100 text-red-700">Admin</span>
                            {% elseif 'ROLE_DEPOT_VENTE' in user.roles %}
                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-amber-100 text-amber-700">Dépôt-vente</span>
                            {% else %}
                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-gray-100 text-gray-600">Client</span>
                            {% endif %}
                        </td>
                        <td class="px-4 py-3 text-center">
                            {% if commandeCount > 0 %}
                                <a href="{{ path('admin_commandes', {statut: ''}) }}?user={{ user.id }}"
                                   class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-primary/10 text-primary font-bold text-sm hover:bg-primary hover:text-white transition">
                                    {{ commandeCount }}
                                </a>
                            {% else %}
                                <span class="text-gray-300">0</span>
                            {% endif %}
                        </td>
                        <td class="px-4 py-3 text-gray-400 text-xs">
                            {{ user.createdAt|date('d/m/Y') }}
                        </td>
                        <td class="px-4 py-3 text-right">
                            <div class="flex items-center justify-end gap-2">
                                {% if not isSelf %}
                                    {# Toggle admin role #}
                                    <form method="post" action="{{ path('admin_utilisateurs_toggle_admin', {id: user.id}) }}">
                                        {% if 'ROLE_ADMIN' in user.roles %}
                                            <button type="submit"
                                                    class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-red-50 text-red-600 hover:bg-red-100 transition"
                                                    title="Retirer le rôle admin">
                                                Retirer admin
                                            </button>
                                        {% else %}
                                            <button type="submit"
                                                    class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-blue-50 text-blue-600 hover:bg-blue-100 transition"
                                                    title="Promouvoir en admin">
                                                Admin
                                            </button>
                                        {% endif %}
                                    </form>

                                    {# Toggle dépôt-vente role #}
                                    {% if 'ROLE_ADMIN' not in user.roles %}
                                        <form method="post" action="{{ path('admin_utilisateurs_toggle_depot_vente', {id: user.id}) }}">
                                            {% if 'ROLE_DEPOT_VENTE' in user.roles %}
                                                <button type="submit"
                                                        class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-amber-50 text-amber-600 hover:bg-amber-100 transition"
                                                        title="Retirer le rôle dépôt-vente">
                                                    Retirer dépôt-vente
                                                </button>
                                            {% else %}
                                                <button type="submit"
                                                        class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-amber-50 text-amber-600 hover:bg-amber-100 transition"
                                                        title="Assigner dépôt-vente">
                                                    Dépôt-vente
                                                </button>
                                            {% endif %}
                                        </form>
                                    {% endif %}

                                    {# Delete user #}
                                    <form method="post" action="{{ path('admin_utilisateurs_delete', {id: user.id}) }}"
                                          onsubmit="window.confirmForm(event, this, 'Supprimer {{ user.prenom }} {{ user.nom }} ? Cette action est irréversible.')">
                                        <button type="submit"
                                                class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-gray-100 text-gray-500 hover:bg-red-50 hover:text-red-600 transition"
                                                title="Supprimer l'utilisateur">
                                            Supprimer
                                        </button>
                                    </form>
                                {% else %}
                                    <span class="text-xs text-gray-300">—</span>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="px-4 py-8 text-center text-gray-400">Aucun utilisateur enregistré.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
