{% extends 'admin/base_admin.html.twig' %}

{% block title %}Variantes Printful{% endblock %}
{% block page_title %}Variantes synchronisées Printful{% endblock %}
{% block page_subtitle %}
    <p class="text-sm text-gray-500 mt-1">Copiez les <strong>Sync Variant ID</strong> dans les fiches articles (champ "ID Printful" de chaque variante).</p>
{% endblock %}

{% block body %}

    {% if error %}
        <div class="card p-6 border border-red-200 bg-red-50 text-red-700">
            <p class="font-semibold">Erreur de connexion à Printful :</p>
            <p class="mt-1 font-mono text-sm">{{ error }}</p>
            <p class="mt-3 text-sm">Vérifiez que <code>PRINTFUL_API_KEY</code> et <code>PRINTFUL_STORE_ID</code> sont bien définis dans <code>.env.local</code>.</p>
        </div>

    {% elseif products is empty %}
        <div class="card p-8 text-center text-gray-400">
            Aucun produit synchronisé trouvé dans votre boutique Printful.
        </div>

    {% else %}
        <div class="space-y-6">
            {% for product in products %}
                <div class="card overflow-hidden">
                    <div class="px-6 py-4 bg-gray-50 border-b flex items-center justify-between">
                        <h2 class="font-heading font-bold text-lg">{{ product.name }}</h2>
                        <span class="text-xs text-gray-400 font-mono">product #{{ product.id }}</span>
                    </div>
                    <table class="w-full text-sm">
                        <thead class="bg-gray-50 border-b text-xs text-gray-500 uppercase">
                            <tr>
                                <th class="text-left px-6 py-2">Variante</th>
                                <th class="text-left px-6 py-2">SKU</th>
                                <th class="text-left px-6 py-2 font-bold text-primary">Sync Variant ID</th>
                                <th class="px-6 py-2"></th>
                            </tr>
                        </thead>
                        <tbody class="divide-y">
                            {% for v in product.variants %}
                                <tr class="{{ v.synced ? 'hover:bg-gray-50' : 'bg-red-50 hover:bg-red-100' }}">
                                    <td class="px-6 py-3">{{ v.name }}</td>
                                    <td class="px-6 py-3 font-mono text-xs text-gray-500">{{ v.sku ?: '—' }}</td>
                                    <td class="px-6 py-3">
                                        {% if v.synced %}
                                            <span class="font-mono font-bold text-primary text-base">{{ v.id }}</span>
                                        {% else %}
                                            <span class="font-mono text-red-400 line-through text-base">{{ v.id }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="px-6 py-3">
                                        {% if v.synced %}
                                            <button type="button"
                                                    onclick="navigator.clipboard.writeText('{{ v.id }}'); this.textContent='Copié ✓'; setTimeout(() => this.textContent='Copier', 1500)"
                                                    class="text-xs px-3 py-1 border border-gray-300 rounded hover:bg-gray-100 transition">
                                                Copier
                                            </button>
                                        {% else %}
                                            <span class="text-xs text-red-500 font-medium">Non synchronisé — configurer dans Printful</span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endfor %}
        </div>
    {% endif %}

{% endblock %}
