{% extends 'admin/base_admin.html.twig' %}

{% block title %}Import Printful{% endblock %}
{% block page_title %}Import articles Printful{% endblock %}
{% block page_subtitle %}
    <p class="text-sm text-gray-500 mt-1">Sélectionnez les produits à importer. Chaque produit devient un article avec ses variantes (Taille + Couleur) automatiquement créées.</p>
{% endblock %}

{% block body %}

{% if error %}
    <div class="card p-6 border border-red-200 bg-red-50 text-red-700">
        <p class="font-semibold">Erreur de connexion à Printful :</p>
        <p class="mt-1 font-mono text-sm">{{ error }}</p>
        <p class="mt-3 text-sm">Vérifiez que <code>PRINTFUL_API_KEY</code> et <code>PRINTFUL_STORE_ID</code> sont bien définis dans <code>.env.local</code>.</p>
    </div>

{% elseif products is empty %}
    <div class="card p-8 text-center text-gray-400">
        Aucun produit synchronisé trouvé dans votre boutique Printful.
    </div>

{% else %}

<div x-data="importApp()" class="space-y-6">

    <form method="post" action="{{ path('admin_printful_import') }}" @submit.prevent="submitImport($event)">

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

            {# ── Colonne gauche : sélection produits ─────────────────── #}
            <div class="lg:col-span-2 space-y-4">

                {# Barre de contrôle #}
                <div class="card px-4 py-3 flex items-center justify-between">
                    <div class="flex items-center gap-4">
                        <label class="flex items-center gap-2 cursor-pointer text-sm font-medium text-gray-700">
                            <input type="checkbox" @change="toggleAll($event.target.checked)"
                                   :checked="allSelected"
                                   class="w-4 h-4 rounded border-gray-300 text-primary">
                            Tout sélectionner
                        </label>
                        <span class="text-sm text-gray-500">
                            <span x-text="selected.length"></span> / {{ products|length }} produit(s)
                        </span>
                    </div>
                    <span class="text-xs text-gray-400">Seules les variantes synchronisées sont importées</span>
                </div>

                {# Liste des produits #}
                {% for product in products %}
                    {% set syncedCount = product.variants|filter(v => v.synced)|length %}
                    {% set totalCount  = product.variants|length %}
                    <div class="card overflow-hidden"
                         :class="selected.includes({{ product.id }}) ? 'ring-2 ring-primary' : ''">
                        <label class="flex items-start gap-4 p-4 cursor-pointer hover:bg-gray-50 transition">
                            <input type="checkbox"
                                   name="productIds[]"
                                   value="{{ product.id }}"
                                   x-model="selected"
                                   :value="{{ product.id }}"
                                   class="mt-1 w-4 h-4 rounded border-gray-300 text-primary flex-shrink-0">

                            {% if product.thumbnail %}
                                <img src="{{ product.thumbnail }}" alt="{{ product.name }}"
                                     class="w-16 h-16 object-cover rounded flex-shrink-0 bg-gray-100">
                            {% else %}
                                <div class="w-16 h-16 rounded bg-gray-100 flex-shrink-0 flex items-center justify-center text-gray-300">
                                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                    </svg>
                                </div>
                            {% endif %}

                            <div class="flex-1 min-w-0">
                                <p class="font-semibold text-gray-900 truncate">{{ product.name }}</p>
                                <p class="text-xs text-gray-400 font-mono mt-0.5">ID #{{ product.id }}</p>
                                <div class="flex items-center gap-3 mt-2">
                                    {% if syncedCount > 0 %}
                                        <span class="inline-flex items-center gap-1 text-xs px-2 py-0.5 rounded-full bg-green-100 text-green-700 font-medium">
                                            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                                            {{ syncedCount }} variante{{ syncedCount > 1 ? 's' : '' }} synchronisée{{ syncedCount > 1 ? 's' : '' }}
                                        </span>
                                    {% endif %}
                                    {% if totalCount - syncedCount > 0 %}
                                        <span class="text-xs text-red-400">{{ totalCount - syncedCount }} non sync.</span>
                                    {% endif %}
                                </div>

                                {# Aperçu des variantes #}
                                <div class="mt-2 flex flex-wrap gap-1">
                                    {% for v in product.variants|slice(0, 8) %}
                                        <span class="text-xs px-1.5 py-0.5 rounded {{ v.synced ? 'bg-gray-100 text-gray-600' : 'bg-red-50 text-red-400 line-through' }}">
                                            {{ v.name|replace({(product.name ~ ' - '): ''}) }}
                                        </span>
                                    {% endfor %}
                                    {% if product.variants|length > 8 %}
                                        <span class="text-xs text-gray-400">+{{ product.variants|length - 8 }}</span>
                                    {% endif %}
                                </div>
                            </div>
                        </label>
                    </div>
                {% endfor %}
            </div>

            {# ── Colonne droite : paramètres ──────────────────────────── #}
            <div class="space-y-4">
                <div class="card p-6 space-y-5 sticky top-6">
                    <h3 class="font-heading font-bold text-lg border-b pb-3">Paramètres d'import</h3>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Collection</label>
                        <select name="collection" class="input-field w-full">
                            <option value="">— Aucune —</option>
                            {% for col in collections %}
                                <option value="{{ col.id }}">{{ col.nom }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Grille de prix</label>
                        <select name="grillePrix" class="input-field w-full">
                            <option value="">— Aucune —</option>
                            {% for g in grilles %}
                                <option value="{{ g.id }}">{{ g.nom }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Fournisseur</label>
                        <select name="fournisseur" class="input-field w-full">
                            <option value="">— Aucun —</option>
                            {% for f in fournisseurs %}
                                <option value="{{ f.id }}">{{ f.nom }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Prix de base (€)</label>
                        <input type="number" name="prixBase" step="0.01" min="0" value="0"
                               class="input-field w-full">
                        <p class="text-xs text-gray-400 mt-1">Appliqué à tous les articles importés. Modifiable ensuite dans chaque fiche article.</p>
                    </div>

                    <div class="pt-3 border-t">
                        <p class="text-xs text-gray-500 mb-3">
                            Les articles sont créés <strong>inactifs</strong> — vous devez les activer manuellement après avoir ajouté les images et vérifié les prix.
                        </p>
                        <button type="submit"
                                :disabled="selected.length === 0"
                                :class="selected.length === 0 ? 'opacity-40 cursor-not-allowed' : ''"
                                class="w-full btn-primary py-3 rounded-lg font-bold">
                            Importer <span x-text="selected.length"></span> produit<span x-show="selected.length > 1">s</span>
                        </button>
                    </div>
                </div>
            </div>

        </div>

    </form>
</div>

<script>
function importApp() {
    return {
        selected: [],
        get allSelected() {
            return this.selected.length === {{ products|length }};
        },
        toggleAll(checked) {
            if (checked) {
                this.selected = {{ products|map(p => p.id)|json_encode|raw }};
            } else {
                this.selected = [];
            }
        },
        submitImport(e) {
            if (this.selected.length === 0) return;
            e.target.submit();
        },
    };
}
</script>

{% endif %}

{% endblock %}
