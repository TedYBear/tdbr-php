{% extends 'admin/base_admin.html.twig' %}

{% block title %}Import Printful{% endblock %}
{% block page_title %}Import articles Printful{% endblock %}
{% block page_subtitle %}
    <p class="text-sm text-gray-500 mt-1">
        Sélectionnez les produits à importer. Les variantes sont parsées au format <code>titre/couleur/taille</code>.
        Les valeurs sont validées contre vos <a href="{{ path('admin_caracteristiques') }}" class="underline text-primary">Caractéristiques</a>.
    </p>
{% endblock %}

{% block body %}

{% if error %}
    <div class="card p-6 border border-red-200 bg-red-50 text-red-700">
        <p class="font-semibold">Erreur de connexion à Printful :</p>
        <p class="mt-1 font-mono text-sm">{{ error }}</p>
        <p class="mt-3 text-sm">Vérifiez que <code>PRINTFUL_API_KEY</code> et <code>PRINTFUL_STORE_ID</code> sont bien définis dans <code>.env.local</code>.</p>
    </div>

{% elseif products is empty %}
    <div class="card p-8 text-center text-gray-400">
        Aucun produit synchronisé trouvé dans votre boutique Printful.
    </div>

{% else %}

{# Barre de cache #}
<div class="flex items-center justify-between mb-4 px-4 py-2.5 rounded-lg bg-gray-50 border border-gray-200 text-xs text-gray-500">
    <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        {% if cachedAt %}
            {% set ageMin = cacheAge // 60 %}
            {% if ageMin < 1 %}
                Données Printful chargées à l'instant
            {% elseif ageMin < 60 %}
                Données en cache depuis {{ ageMin }} min — expire dans {{ ((cacheTtl - cacheAge) // 60)|abs }} min
            {% else %}
                Données en cache depuis {{ (ageMin / 60)|round(1) }}h
            {% endif %}
        {% else %}
            Données Printful
        {% endif %}
    </div>
    <form method="post" action="{{ path('admin_printful_import_refresh') }}">
        <button type="submit"
                class="flex items-center gap-1.5 px-3 py-1 rounded-md border border-gray-300 bg-white hover:bg-gray-100 text-gray-600 font-medium transition">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
            Rafraîchir
        </button>
    </form>
</div>

{# Résumé des valeurs connues + deltas #}
<div class="flex flex-wrap gap-3 mb-4 text-xs">
    {% if couleurValues is not empty %}
        <div class="card px-3 py-2 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-green-400 inline-block"></span>
            <span class="text-gray-600">Couleurs :</span>
            <span class="font-mono text-gray-800">{{ couleurValues|join(', ') }}</span>
        </div>
    {% else %}
        <div class="card px-3 py-2 text-amber-600">Aucune caractéristique "Couleur" définie.</div>
    {% endif %}
    {% if tailleValues is not empty %}
        <div class="card px-3 py-2 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-green-400 inline-block"></span>
            <span class="text-gray-600">Tailles :</span>
            <span class="font-mono text-gray-800">{{ tailleValues|join(', ') }}</span>
        </div>
    {% else %}
        <div class="card px-3 py-2 text-amber-600">Aucune caractéristique "Taille" définie.</div>
    {% endif %}
    {% if tailleDelta is not empty %}
        <div class="card px-3 py-2 flex items-center gap-2 text-gray-600">
            <span class="text-gray-500">Surcoût automatique :</span>
            {% for taille, delta in tailleDelta %}
                <span class="px-1.5 py-0.5 rounded bg-blue-50 text-blue-700 font-mono">{{ taille }} +{{ delta }}€</span>
            {% endfor %}
        </div>
    {% endif %}
</div>

<div x-data="importApp()" class="space-y-6">
    <form method="post" action="{{ path('admin_printful_import') }}">

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

            {# ── Colonne gauche : sélection produits ─────────────────── #}
            <div class="lg:col-span-2 space-y-4">

                {# Barre de contrôle #}
                <div class="card px-4 py-3 flex items-center justify-between">
                    <div class="flex items-center gap-4">
                        <label class="flex items-center gap-2 cursor-pointer text-sm font-medium text-gray-700">
                            <input type="checkbox" @change="toggleAll($event.target.checked)"
                                   :checked="allSelected"
                                   class="w-4 h-4 rounded border-gray-300 text-primary">
                            Tout sélectionner
                        </label>
                        <span class="text-sm text-gray-500">
                            <span x-text="selected.length"></span> / {{ products|length }} produit(s)
                        </span>
                    </div>
                    <span class="text-xs text-gray-400">Seules les variantes synchronisées sont importées</span>
                </div>

                {# Liste des produits #}
                {% for product in products %}
                    {% set syncedVariants = product.variants|filter(v => v.synced) %}
                    {% set syncedCount    = syncedVariants|length %}
                    {% set totalCount     = product.variants|length %}
                    {% set invalidCount   = syncedVariants|filter(v => not v.valid)|length %}
                    {% set mockupCount    = product.mockups|length %}
                    {% set linkedNom      = product.linkedNom %}
                    {% set linkedByIdFlag = product.linkedByPfId %}

                    <div class="card overflow-hidden transition"
                         :class="selected.includes({{ product.id }}) ? 'ring-2 ring-primary' : ''">

                        <label class="flex items-start gap-4 p-4 cursor-pointer hover:bg-gray-50 transition">
                            <input type="checkbox"
                                   name="productIds[]"
                                   :value="{{ product.id }}"
                                   x-model="selected"
                                   class="mt-1 w-4 h-4 rounded border-gray-300 text-primary flex-shrink-0">

                            {% if product.thumbnail %}
                                <img src="{{ product.thumbnail }}" alt="{{ product.name }}"
                                     class="w-16 h-16 object-cover rounded flex-shrink-0 bg-gray-100">
                            {% else %}
                                <div class="w-16 h-16 rounded bg-gray-100 flex-shrink-0 flex items-center justify-center text-gray-300">
                                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                    </svg>
                                </div>
                            {% endif %}

                            <div class="flex-1 min-w-0">
                                <p class="font-semibold text-gray-900 truncate">{{ product.name }}</p>
                                <div class="flex items-center gap-2 mt-0.5">
                                    <p class="text-xs text-gray-400 font-mono">ID #{{ product.id }}</p>
                                    {% if linkedNom %}
                                        {% if linkedByIdFlag %}
                                            <span class="text-xs px-1.5 py-0.5 rounded bg-indigo-100 text-indigo-700 font-medium" title="Lié par printfulProductId">
                                                → {{ linkedNom }}
                                            </span>
                                        {% else %}
                                            <span class="text-xs px-1.5 py-0.5 rounded bg-gray-100 text-gray-600" title="Correspondance par slug — l'ID Printful sera associé automatiquement">
                                                → {{ linkedNom }} <span class="text-gray-400">(slug)</span>
                                            </span>
                                        {% endif %}
                                    {% endif %}
                                </div>

                                {# Badges statut #}
                                <div class="flex flex-wrap items-center gap-2 mt-2">
                                    {% if syncedCount > 0 %}
                                        <span class="inline-flex items-center gap-1 text-xs px-2 py-0.5 rounded-full bg-green-100 text-green-700 font-medium">
                                            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                                            {{ syncedCount }} variante{{ syncedCount > 1 ? 's' : '' }} sync.
                                        </span>
                                    {% endif %}
                                    {% if totalCount - syncedCount > 0 %}
                                        <span class="text-xs text-gray-400">{{ totalCount - syncedCount }} non sync. (ignorées)</span>
                                    {% endif %}
                                    {% if mockupCount > 0 %}
                                        <span class="inline-flex items-center gap-1 text-xs px-2 py-0.5 rounded-full bg-blue-100 text-blue-700">
                                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                            {{ mockupCount }} maquette{{ mockupCount > 1 ? 's' : '' }}
                                        </span>
                                    {% endif %}
                                    {% if invalidCount > 0 %}
                                        <span class="inline-flex items-center gap-1 text-xs px-2 py-0.5 rounded-full bg-amber-100 text-amber-700 font-medium">
                                            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
                                            {{ invalidCount }} valeur(s) inconnue(s)
                                        </span>
                                    {% endif %}
                                </div>

                                {# Tableau des variantes parsées (synced uniquement) #}
                                {% if syncedVariants is not empty %}
                                    <div class="mt-3 overflow-x-auto">
                                        <table class="text-xs w-full">
                                            <thead>
                                                <tr class="text-gray-400 border-b">
                                                    <th class="text-left pb-1 pr-4 font-medium">Nom Printful</th>
                                                    <th class="text-left pb-1 pr-4 font-medium">Couleur</th>
                                                    <th class="text-left pb-1 pr-3 font-medium">Taille</th>
                                                    <th class="text-left pb-1 font-medium">Delta</th>
                                                </tr>
                                            </thead>
                                            <tbody class="divide-y divide-gray-50">
                                                {% for v in syncedVariants %}
                                                    <tr class="{{ v.valid ? '' : 'bg-amber-50' }}">
                                                        <td class="py-1 pr-4 font-mono text-gray-400 max-w-[180px] truncate">{{ v.name }}</td>
                                                        <td class="py-1 pr-4">
                                                            {% if v.couleurOk %}
                                                                <span class="px-1.5 py-0.5 rounded bg-green-100 text-green-700">{{ v.parsed.couleur }}</span>
                                                            {% else %}
                                                                <span class="px-1.5 py-0.5 rounded bg-amber-100 text-amber-700" title="Valeur inconnue">{{ v.parsed.couleur }} ?</span>
                                                            {% endif %}
                                                        </td>
                                                        <td class="py-1 pr-3">
                                                            {% if v.parsed.taille %}
                                                                {% if v.tailleOk %}
                                                                    <span class="px-1.5 py-0.5 rounded bg-green-100 text-green-700">{{ v.parsed.taille }}</span>
                                                                {% else %}
                                                                    <span class="px-1.5 py-0.5 rounded bg-amber-100 text-amber-700" title="Valeur inconnue">{{ v.parsed.taille }} ?</span>
                                                                {% endif %}
                                                            {% else %}
                                                                <span class="text-gray-300">—</span>
                                                            {% endif %}
                                                        </td>
                                                        <td class="py-1">
                                                            {% if v.delta is not null %}
                                                                <span class="px-1.5 py-0.5 rounded bg-blue-50 text-blue-600 font-mono">+{{ v.delta }}€</span>
                                                            {% else %}
                                                                <span class="text-gray-300">—</span>
                                                            {% endif %}
                                                        </td>
                                                    </tr>
                                                {% endfor %}
                                            </tbody>
                                        </table>
                                    </div>
                                {% endif %}
                            </div>
                        </label>

                        {# Aperçu maquettes #}
                        {% if product.mockups is not empty %}
                            <div class="px-4 pb-3 border-t pt-3 bg-gray-50">
                                <p class="text-xs text-gray-400 mb-2">Maquettes ({{ product.mockups|length }})</p>
                                <div class="flex gap-2 overflow-x-auto">
                                    {% for url in product.mockups|slice(0, 6) %}
                                        <img src="{{ url }}" alt="maquette"
                                             class="w-20 h-20 object-cover rounded border border-gray-200 flex-shrink-0">
                                    {% endfor %}
                                    {% if product.mockups|length > 6 %}
                                        <div class="w-20 h-20 rounded border border-gray-200 flex-shrink-0 flex items-center justify-center text-xs text-gray-400 bg-white">
                                            +{{ product.mockups|length - 6 }}
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        {% endif %}

                    </div>
                {% endfor %}
            </div>

            {# ── Colonne droite : paramètres ──────────────────────────── #}
            <div class="space-y-4">
                <div class="card p-6 space-y-5 sticky top-6">
                    <h3 class="font-heading font-bold text-lg border-b pb-3">Paramètres d'import</h3>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Collection</label>
                        <select name="collection" class="input-field w-full">
                            <option value="">— Aucune —</option>
                            {% for col in collections %}
                                <option value="{{ col.id }}">{{ col.nom }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Grille de prix</label>
                        <select name="grillePrix" class="input-field w-full">
                            <option value="">— Aucune —</option>
                            {% for g in grilles %}
                                <option value="{{ g.id }}">{{ g.nom }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Fournisseur</label>
                        {% if printfulFournisseur %}
                            <div class="input-field w-full bg-gray-50 text-gray-700 flex items-center gap-2">
                                <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                                {{ printfulFournisseur.nom }}
                            </div>
                            <p class="text-xs text-gray-400 mt-1">Attribué automatiquement.</p>
                        {% else %}
                            <div class="p-3 rounded-lg border border-amber-200 bg-amber-50 text-amber-700 text-xs">
                                Aucun fournisseur "Printful" trouvé. <a href="{{ path('admin_fournisseurs') }}" class="underline font-medium">Créez-le</a> pour l'attribuer automatiquement.
                            </div>
                        {% endif %}
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Prix de base (€)</label>
                        <input type="number" name="prixBase" step="0.01" min="0" value="0"
                               class="input-field w-full">
                        <p class="text-xs text-gray-400 mt-1">Modifiable ensuite dans chaque fiche article.</p>
                    </div>

                    <div>
                        <label class="flex items-start gap-3 cursor-pointer">
                            <input type="checkbox" name="withMockups" value="1" checked
                                   class="mt-0.5 w-4 h-4 rounded border-gray-300 text-primary">
                            <div>
                                <span class="text-sm font-medium text-gray-700">Importer les maquettes</span>
                                <p class="text-xs text-gray-400 mt-0.5">Les preview_url Printful sont ajoutées comme images de l'article.</p>
                            </div>
                        </label>
                    </div>

                    <div class="pt-3 border-t space-y-3">
                        <p class="text-xs text-gray-500">
                            Les articles sont créés <strong>inactifs</strong>. Les valeurs <span class="px-1 rounded bg-amber-100 text-amber-700 text-xs">? inconnues</span> sont importées avec un avertissement.
                        </p>
                        <button type="submit"
                                :disabled="selected.length === 0"
                                :class="selected.length === 0 ? 'opacity-40 cursor-not-allowed' : ''"
                                class="w-full btn-primary py-3 rounded-lg font-bold">
                            Importer <span x-text="selected.length"></span> produit<span x-show="selected.length !== 1">s</span>
                        </button>
                    </div>
                </div>
            </div>

        </div>

    </form>
</div>

<script>
function importApp() {
    return {
        selected: [],
        get allSelected() {
            return this.selected.length === {{ products|length }};
        },
        toggleAll(checked) {
            this.selected = checked ? {{ products|map(p => p.id)|json_encode|raw }} : [];
        },
    };
}
</script>

{% endif %}

{% endblock %}
