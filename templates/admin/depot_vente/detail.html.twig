{% extends 'admin/base_admin.html.twig' %}
{% block title %}{{ depot.nom }}{% endblock %}
{% block page_title %}{{ depot.nom }}{% endblock %}

{% block body %}
<div x-data="{
    openFond: false,
    openVente: false,
    openReinit: false,
    fondSens: 'ajout',
    panel: null,
    collectionId: null,
    togglePanel(name) { this.panel = this.panel === name ? null : name; }
}">

    {# ── En-tête ──────────────────────────────────────────────────────────── #}
    <div class="flex flex-wrap items-start justify-between gap-4 mb-6">
        <div>
            <div class="flex items-center gap-2 text-sm text-gray-400 mb-1">
                <a href="{{ path('admin_depot_ventes') }}" class="hover:text-gray-600 transition">Dépôts-vente</a>
                <span>/</span>
                <span class="text-gray-700 font-medium">{{ depot.nom }}</span>
            </div>
            {% if depot.ville %}<p class="text-sm text-gray-500">{{ depot.codePostal }} {{ depot.ville }}</p>{% endif %}
            {% if depot.user %}<p class="text-xs text-gray-400 mt-0.5">Géré par {{ depot.user.prenom }} {{ depot.user.nom }}</p>{% endif %}
        </div>
        <div class="flex items-center gap-2">
            <a href="{{ path('admin_depot_ventes_edit', {id: depot.id}) }}"
               class="px-3 py-1.5 rounded-lg text-sm font-medium bg-gray-100 text-gray-600 hover:bg-gray-200 transition">
                Modifier
            </a>
            <button @click="openReinit = true"
                    style="padding:0.375rem 0.75rem;border-radius:0.5rem;border:1px solid #fca5a5;background:#fff;color:#dc2626;font-size:0.8rem;font-weight:600;cursor:pointer;font-family:inherit;">
                Réinit.
            </button>
        </div>
    </div>

    {# Modal Réinitialisation #}
    <div x-show="openReinit" x-cloak
         style="position:fixed;inset:0;z-index:10002;background:rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;padding:1rem;"
         @click.self="openReinit = false">
        <div style="background:#fff;border-radius:1.25rem;padding:2rem;max-width:22rem;width:100%;box-shadow:0 20px 60px rgba(0,0,0,0.3);">
            <h3 style="font-size:1rem;font-weight:700;color:#111827;margin:0 0 0.5rem;">Réinitialiser le dépôt-vente</h3>
            <p style="font-size:0.85rem;color:#6b7280;margin:0 0 1.5rem;line-height:1.5;">
                Cette action supprime <strong>tous les articles suivis</strong>, leurs stocks et <strong>tout l'historique</strong> des transactions. Irréversible.
            </p>
            <div style="display:flex;gap:0.75rem;">
                <button type="button" @click="openReinit = false"
                        style="flex:1;padding:0.6rem;border-radius:0.625rem;border:1.5px solid #d1d5db;background:#fff;font-weight:600;cursor:pointer;font-size:0.875rem;font-family:inherit;">
                    Annuler
                </button>
                <form method="post" action="{{ path('admin_depot_ventes_reinit', {id: depot.id}) }}" style="flex:1;">
                    <button type="submit"
                            style="width:100%;padding:0.6rem;border-radius:0.625rem;border:none;background:#dc2626;color:#fff;font-weight:600;cursor:pointer;font-size:0.875rem;font-family:inherit;">
                        Réinitialiser
                    </button>
                </form>
            </div>
        </div>
    </div>

    {# ── Cartes KPI ───────────────────────────────────────────────────────── #}
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
        <div class="card p-5">
            <div class="flex items-center justify-between mb-3">
                <p class="text-sm text-gray-500">Fond de caisse</p>
                <button @click="openFond = true"
                        class="px-2 py-1 rounded text-xs font-medium bg-primary/10 text-primary hover:bg-primary hover:text-white transition">
                    Ajuster
                </button>
            </div>
            <p class="text-3xl font-bold text-gray-900">{{ depot.fondDeCaisse|number_format(2, ',', ' ') }} €</p>
        </div>

        <div class="card p-5">
            <p class="text-sm text-gray-500 mb-3">Articles en stock</p>
            <p class="text-3xl font-bold text-gray-900">{{ depot.totalStock }}</p>
        </div>

        <div class="card p-5 flex flex-col gap-2 justify-center">
            <button @click="openVente = true"
                    style="background:#111827;color:#fff;border:none;border-radius:0.5rem;padding:0.5rem 1rem;font-size:0.875rem;font-weight:600;cursor:pointer;font-family:inherit;width:100%;">
                Réaliser une vente
            </button>
            <button @click="togglePanel('ajout')"
                    :style="panel === 'ajout' ? 'background:#1e40af;color:#fff;border:none;border-radius:0.5rem;padding:0.5rem 1rem;font-size:0.875rem;font-weight:600;cursor:pointer;font-family:inherit;width:100%;' : 'background:#dbeafe;color:#1e40af;border:none;border-radius:0.5rem;padding:0.5rem 1rem;font-size:0.875rem;font-weight:600;cursor:pointer;font-family:inherit;width:100%;'">
                Ajouter des articles
            </button>
        </div>
    </div>

    {# ════════════════════════════════════════════════════════════════════════
       Panel — Ajouter des articles
    ════════════════════════════════════════════════════════════════════════ #}
    <div x-show="panel === 'ajout'" x-cloak class="card overflow-hidden mb-6">
        <div class="px-5 py-4 border-b border-gray-100">
            <h2 class="font-semibold text-gray-800">Ajouter des articles</h2>
        </div>

        <form method="post" action="{{ path('admin_depot_ventes_ajout', {id: depot.id}) }}">
            <div class="px-5 pt-4 pb-2">
                <label class="block text-sm font-medium text-gray-700 mb-1">Collection</label>
                <select x-model="collectionId"
                        class="w-full max-w-sm border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/50">
                    <option value="">— Sélectionner une collection —</option>
                    {% for categorie in categories %}
                        {% if categorie.collections|length > 0 %}
                            <optgroup label="{{ categorie.nom }}">
                                {% for collection in categorie.collections %}
                                    {% if collection.actif %}
                                        <option value="{{ collection.id }}">{{ collection.nom }}</option>
                                    {% endif %}
                                {% endfor %}
                            </optgroup>
                        {% endif %}
                    {% endfor %}
                </select>
            </div>

            {# Articles par collection — affichés selon la sélection #}
            {% for categorie in categories %}
                {% for collection in categorie.collections %}
                    {% if collection.actif %}
                        <div x-show="collectionId == '{{ collection.id }}'" x-cloak>
                            <div class="px-5 py-3 grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-3">
                                {% for article in collection.articles %}
                                    {% if article.actif %}
                                        {% set dejaAjoute = false %}
                                        {% for variante in article.variantes %}
                                            {% if variante.actif and stockMap[variante.id] is defined %}
                                                {% set dejaAjoute = true %}
                                            {% endif %}
                                        {% endfor %}
                                        <label class="flex border border-gray-200 rounded-xl overflow-hidden cursor-pointer {{ dejaAjoute ? 'opacity-50 cursor-default' : 'hover:border-blue-300 hover:shadow-sm' }}" style="transition:border-color .15s,box-shadow .15s;">
                                            {# Image #}
                                            {% set imgUrl = article.firstImageUrl %}
                                            {% if imgUrl %}
                                                <img src="{{ imgUrl }}" alt="{{ article.nom }}" style="width:90px;flex-shrink:0;object-fit:cover;">
                                            {% else %}
                                                <div style="width:90px;flex-shrink:0;background:#f3f4f6;display:flex;align-items:center;justify-content:center;">
                                                    <svg width="24" height="24" fill="none" stroke="#d1d5db" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v13.5A1.5 1.5 0 003.75 21z"/></svg>
                                                </div>
                                            {% endif %}
                                            {# Contenu #}
                                            <div class="flex-1 min-w-0 p-3 flex items-center gap-3">
                                                <div class="flex-1 min-w-0">
                                                    <p class="text-sm font-semibold text-gray-900 leading-snug">{{ article.nom }}</p>
                                                    {% if dejaAjoute %}
                                                        <p class="text-xs text-gray-400 italic mt-0.5">déjà ajouté</p>
                                                    {% endif %}
                                                </div>
                                                <input type="checkbox" name="articles[]" value="{{ article.id }}"
                                                       {{ dejaAjoute ? 'checked disabled' : '' }}
                                                       class="rounded border-gray-300 flex-shrink-0 w-4 h-4">
                                            </div>
                                        </label>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}
            {% endfor %}

            <div class="px-5 py-4 border-t border-gray-100 flex justify-end">
                <button type="submit"
                        style="background:#1e40af;color:#fff;border:none;border-radius:0.5rem;padding:0.5rem 1.25rem;font-size:0.875rem;font-weight:600;cursor:pointer;font-family:inherit;">
                    Enregistrer la sélection
                </button>
            </div>
        </form>
    </div>

    {# ── Stock (consultation + édition inline) ───────────────────────────── #}
    <div class="card overflow-hidden mb-6">
        <div class="px-5 py-4 border-b border-gray-100">
            <h2 class="font-semibold text-gray-800">Stock</h2>
        </div>

        {% if articlesAvecStockItems is empty %}
            <div class="px-5 py-10 text-center text-gray-400 text-sm">Aucun article suivi.</div>
        {% else %}
            <div class="p-5 grid grid-cols-1 sm:grid-cols-2 gap-3">
                {% for article in articlesAvecStockItems %}
                    {% set variantesSuivies = [] %}
                    {% set totalQty = 0 %}
                    {% for variante in article.variantes %}
                        {% if variante.actif %}
                            {% set stockItem = stockMap[variante.id] ?? null %}
                            {% if stockItem %}
                                {% set variantesSuivies = variantesSuivies|merge([{
                                    'variante': variante,
                                    'stockItem': stockItem,
                                    'prix': prixMap[variante.id] ?? null
                                }]) %}
                                {% set totalQty = totalQty + stockItem.quantite %}
                            {% endif %}
                        {% endif %}
                    {% endfor %}

                    {% if variantesSuivies|length > 0 %}
                        <div x-data="{ editing: false, confirmDelete: false }"
                             style="position:relative;display:flex;border:1px solid #e5e7eb;border-radius:0.75rem;overflow:hidden;">

                            {# Overlay confirmation suppression #}
                            <div x-show="confirmDelete" x-cloak
                                 style="position:absolute;inset:0;background:rgba(255,255,255,0.96);z-index:10;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:0.625rem;padding:1rem;">
                                <p style="font-size:0.78rem;font-weight:600;color:#111827;text-align:center;">Retirer cet article du suivi ?</p>
                                <div style="display:flex;gap:0.5rem;">
                                    <button type="button" @click="confirmDelete = false"
                                            style="padding:0.3rem 0.75rem;border:1.5px solid #d1d5db;border-radius:0.5rem;background:#fff;font-size:0.75rem;font-weight:600;cursor:pointer;font-family:inherit;">Non</button>
                                    <button type="button" onclick="document.getElementById('del-stock-{{ article.id }}').submit()"
                                            style="padding:0.3rem 0.75rem;border:none;border-radius:0.5rem;background:#dc2626;color:#fff;font-size:0.75rem;font-weight:600;cursor:pointer;font-family:inherit;">Supprimer</button>
                                </div>
                            </div>

                            {# Image 1/4 #}
                            {% set imgUrl = article.firstImageUrl %}
                            {% if imgUrl %}
                                <img src="{{ imgUrl }}" alt="{{ article.nom }}" style="width:25%;flex-shrink:0;object-fit:cover;">
                            {% else %}
                                <div style="width:25%;flex-shrink:0;background:#f3f4f6;display:flex;align-items:center;justify-content:center;">
                                    <svg width="20" height="20" fill="none" stroke="#d1d5db" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v13.5A1.5 1.5 0 003.75 21z"/></svg>
                                </div>
                            {% endif %}

                            {# Contenu 3/4 #}
                            <div style="flex:1;min-width:0;padding:0.625rem 0.75rem;">
                                {# En-tête : nom + boutons d'action #}
                                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.4rem;gap:0.25rem;">
                                    <p style="font-size:0.8rem;font-weight:700;color:#111827;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;">{{ article.nom }}</p>
                                    <div style="display:flex;gap:0.25rem;flex-shrink:0;">
                                        {# Bouton modifier (crayon) #}
                                        <button type="button" @click="editing = !editing"
                                                :title="editing ? 'Annuler' : 'Modifier les quantités'"
                                                :style="editing ? 'color:#1e40af;background:#eff6ff;border:1px solid #bfdbfe;' : 'color:#6b7280;background:#f9fafb;border:1px solid #e5e7eb;'"
                                                style="width:1.625rem;height:1.625rem;border-radius:0.375rem;cursor:pointer;display:flex;align-items:center;justify-content:center;padding:0;font-family:inherit;">
                                            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125"/></svg>
                                        </button>
                                        {# Bouton supprimer (poubelle) — seulement si tout le stock est à 0 #}
                                        {% if totalQty == 0 %}
                                        <button type="button" @click="confirmDelete = true" title="Retirer cet article"
                                                style="width:1.625rem;height:1.625rem;border-radius:0.375rem;cursor:pointer;display:flex;align-items:center;justify-content:center;padding:0;color:#dc2626;background:#fff5f5;border:1px solid #fecaca;font-family:inherit;">
                                            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"/></svg>
                                        </button>
                                        {% endif %}
                                    </div>
                                </div>

                                {# Mode lecture #}
                                <div x-show="!editing" style="display:flex;flex-direction:column;gap:0.25rem;">
                                    {% for v in variantesSuivies %}
                                        {% if v.stockItem.quantite > 0 %}
                                            <div style="display:flex;align-items:center;gap:0.375rem;">
                                                <span style="flex:1;font-size:0.7rem;color:#374151;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{ v.variante.nom }}</span>
                                                {% if v.prix is not null %}<span style="font-size:0.7rem;color:#6b7280;flex-shrink:0;">{{ v.prix|number_format(2, ',', ' ') }} €</span>{% endif %}
                                                <span style="display:inline-flex;align-items:center;justify-content:center;width:1.5rem;height:1.5rem;border-radius:9999px;background:#dcfce7;color:#16a34a;font-size:0.7rem;font-weight:700;flex-shrink:0;">{{ v.stockItem.quantite }}</span>
                                            </div>
                                        {% endif %}
                                    {% endfor %}
                                    {% for v in variantesSuivies %}
                                        {% if v.stockItem.quantite == 0 %}
                                            <div style="display:flex;align-items:center;gap:0.375rem;opacity:0.4;">
                                                <span style="flex:1;font-size:0.7rem;color:#374151;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{ v.variante.nom }}</span>
                                                {% if v.prix is not null %}<span style="font-size:0.7rem;color:#6b7280;flex-shrink:0;">{{ v.prix|number_format(2, ',', ' ') }} €</span>{% endif %}
                                                <span style="display:inline-flex;align-items:center;justify-content:center;width:1.5rem;height:1.5rem;border-radius:9999px;background:#f3f4f6;color:#9ca3af;font-size:0.7rem;font-weight:700;flex-shrink:0;">0</span>
                                            </div>
                                        {% endif %}
                                    {% endfor %}
                                </div>

                                {# Mode édition #}
                                <form x-show="editing" method="post"
                                      action="{{ path('admin_depot_ventes_modifier_stock', {id: depot.id}) }}"
                                      style="display:flex;flex-direction:column;gap:0.3rem;">
                                    {% for v in variantesSuivies %}
                                        <div style="display:flex;align-items:center;gap:0.375rem;">
                                            <span style="flex:1;font-size:0.7rem;color:#374151;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{ v.variante.nom }}</span>
                                            {% if v.prix is not null %}<span style="font-size:0.7rem;color:#6b7280;flex-shrink:0;">{{ v.prix|number_format(2, ',', ' ') }} €</span>{% endif %}
                                            <input type="number" name="lignes[{{ v.stockItem.id }}]"
                                                   value="{{ v.stockItem.quantite }}" min="0" step="1"
                                                   style="width:2.75rem;border:1px solid #d1d5db;border-radius:0.375rem;padding:0.15rem 0.25rem;font-size:0.7rem;text-align:center;font-family:inherit;flex-shrink:0;">
                                        </div>
                                    {% endfor %}
                                    <div style="display:flex;gap:0.375rem;margin-top:0.375rem;">
                                        <button type="button" @click="editing = false"
                                                style="flex:1;padding:0.25rem 0;border:1px solid #d1d5db;border-radius:0.375rem;background:#fff;font-size:0.7rem;font-weight:600;cursor:pointer;font-family:inherit;">
                                            Annuler
                                        </button>
                                        <button type="submit"
                                                style="flex:1;padding:0.25rem 0;border:none;border-radius:0.375rem;background:#111827;color:#fff;font-size:0.7rem;font-weight:600;cursor:pointer;font-family:inherit;">
                                            Enregistrer
                                        </button>
                                    </div>
                                </form>
                            </div>

                            {# Formulaire caché pour la suppression #}
                            <form id="del-stock-{{ article.id }}" method="post"
                                  action="{{ path('admin_depot_ventes_supprimer_article', {id: depot.id, articleId: article.id}) }}"
                                  style="display:none;"></form>
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        {% endif %}
    </div>

    {# ── Historique ───────────────────────────────────────────────────────── #}
    <div class="card overflow-hidden">
        <div class="px-5 py-4 border-b border-gray-100">
            <h2 class="font-semibold text-gray-800">Historique</h2>
        </div>
        {% if transactions is empty %}
            <div class="px-5 py-8 text-center text-gray-400 text-sm">Aucune transaction.</div>
        {% else %}
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-gray-50 border-b">
                        <tr>
                            <th class="text-left px-5 py-3 font-semibold text-gray-600">Date</th>
                            <th class="text-left px-4 py-3 font-semibold text-gray-600">Type</th>
                            <th class="text-left px-4 py-3 font-semibold text-gray-600">Détail</th>
                            <th class="text-right px-4 py-3 font-semibold text-gray-600">Montant</th>
                            <th class="text-left px-4 py-3 font-semibold text-gray-600">Par</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        {% for tx in transactions %}
                            {% set colors = {
                                'vente':        'bg-blue-100 text-blue-700',
                                'reassort':     'bg-amber-100 text-amber-700',
                                'fond_ajout':   'bg-green-100 text-green-700',
                                'fond_retrait': 'bg-red-100 text-red-700',
                            } %}
                            <tr class="hover:bg-gray-50">
                                <td class="px-5 py-3 text-gray-400 text-xs whitespace-nowrap">{{ tx.createdAt|date('d/m/Y H:i') }}</td>
                                <td class="px-4 py-3">
                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold {{ colors[tx.type] ?? 'bg-gray-100 text-gray-600' }}">
                                        {{ tx.typeLabel }}
                                    </span>
                                </td>
                                <td class="px-4 py-3 text-gray-600 max-w-xs">
                                    {% if tx.lignes is not empty %}
                                        <ul class="space-y-0.5">
                                            {% for ligne in tx.lignes %}
                                                <li class="text-xs">
                                                    {{ ligne.varianteLabel }} × {{ ligne.quantite }}
                                                    {% if ligne.prixReel %}
                                                        <span class="text-gray-400">({{ ligne.prixReel|number_format(2, ',', ' ') }} €)</span>
                                                    {% endif %}
                                                </li>
                                            {% endfor %}
                                        </ul>
                                    {% endif %}
                                    {% if tx.note %}<p class="text-xs text-gray-400 mt-0.5 italic">{{ tx.note }}</p>{% endif %}
                                </td>
                                <td class="px-4 py-3 text-right font-medium whitespace-nowrap">
                                    {% if tx.montantFond is not null %}
                                        <span class="{{ tx.montantFond >= 0 ? 'text-green-600' : 'text-red-600' }}">
                                            {{ tx.montantFond >= 0 ? '+' : '' }}{{ tx.montantFond|number_format(2, ',', ' ') }} €
                                        </span>
                                    {% else %}
                                        <span class="text-gray-300">—</span>
                                    {% endif %}
                                </td>
                                <td class="px-4 py-3 text-xs text-gray-400">
                                    {{ tx.createdBy ? tx.createdBy.prenom ~ ' ' ~ tx.createdBy.nom : '—' }}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>

    {# ════════════════════════════════════════════════════════════════════════
       Modal — Fond de caisse
    ════════════════════════════════════════════════════════════════════════ #}
    <div x-show="openFond" x-cloak
         style="position:fixed;inset:0;z-index:10001;background:rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;padding:1rem;"
         @click.self="openFond = false">
        <div style="background:#fff;border-radius:1.25rem;padding:2rem;max-width:22rem;width:100%;box-shadow:0 20px 60px rgba(0,0,0,0.3);">
            <h3 style="font-size:1.1rem;font-weight:700;color:#111827;margin:0 0 1.25rem;">Fond de caisse</h3>
            <form method="post" action="{{ path('admin_depot_ventes_fond', {id: depot.id}) }}">
                <div style="margin-bottom:1rem;">
                    <label style="display:block;font-size:0.8rem;font-weight:600;color:#374151;margin-bottom:0.35rem;">Opération</label>
                    <div style="display:flex;gap:0.5rem;">
                        <label style="flex:1;display:flex;align-items:center;justify-content:center;gap:0.5rem;padding:0.5rem;border:1.5px solid #d1d5db;border-radius:0.5rem;cursor:pointer;font-size:0.85rem;font-weight:600;">
                            <input type="radio" name="sens" value="ajout" x-model="fondSens" style="accent-color:#16a34a;"> Ajout
                        </label>
                        <label style="flex:1;display:flex;align-items:center;justify-content:center;gap:0.5rem;padding:0.5rem;border:1.5px solid #d1d5db;border-radius:0.5rem;cursor:pointer;font-size:0.85rem;font-weight:600;">
                            <input type="radio" name="sens" value="retrait" x-model="fondSens" style="accent-color:#dc2626;"> Retrait
                        </label>
                    </div>
                </div>
                <div style="margin-bottom:1rem;">
                    <label style="display:block;font-size:0.8rem;font-weight:600;color:#374151;margin-bottom:0.35rem;">Montant (€)</label>
                    <input type="number" name="montant" min="0.01" step="0.01" required
                           style="width:100%;border:1.5px solid #d1d5db;border-radius:0.5rem;padding:0.5rem 0.75rem;font-size:0.9rem;font-family:inherit;box-sizing:border-box;"
                           placeholder="0.00">
                </div>
                <div style="margin-bottom:1.5rem;">
                    <label style="display:block;font-size:0.8rem;font-weight:600;color:#374151;margin-bottom:0.35rem;">Note (optionnel)</label>
                    <input type="text" name="note"
                           style="width:100%;border:1.5px solid #d1d5db;border-radius:0.5rem;padding:0.5rem 0.75rem;font-size:0.9rem;font-family:inherit;box-sizing:border-box;"
                           placeholder="Ex : versement Myriam">
                </div>
                <div style="display:flex;gap:0.75rem;">
                    <button type="button" @click="openFond = false"
                            style="flex:1;padding:0.6rem;border-radius:0.625rem;border:1.5px solid #d1d5db;background:#fff;font-weight:600;cursor:pointer;font-size:0.875rem;font-family:inherit;">
                        Annuler
                    </button>
                    <button type="submit"
                            style="flex:1;padding:0.6rem;border-radius:0.625rem;border:none;background:#111827;color:#fff;font-weight:600;cursor:pointer;font-size:0.875rem;font-family:inherit;">
                        Confirmer
                    </button>
                </div>
            </form>
        </div>
    </div>

    {# ════════════════════════════════════════════════════════════════════════
       Modal — Réaliser une vente
    ════════════════════════════════════════════════════════════════════════ #}
    <div x-show="openVente" x-cloak
         style="position:fixed;inset:0;z-index:10001;background:rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;padding:1rem;"
         @click.self="openVente = false">
        <div style="background:#fff;border-radius:1.25rem;padding:2rem;max-width:42rem;width:100%;max-height:90vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,0.3);">
            <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;">
                <h3 style="font-size:1.1rem;font-weight:700;color:#111827;flex:1;margin:0;">Réaliser une vente</h3>
                <button @click="openVente = false" style="background:none;border:none;cursor:pointer;padding:0.25rem;color:#6b7280;">
                    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>

            <form method="post" action="{{ path('admin_depot_ventes_vente', {id: depot.id}) }}">
                {% set hasStock = false %}
                {% for article in articles %}
                    {% for variante in article.variantes %}
                        {% if variante.actif %}
                            {% set stockItem = stockMap[variante.id] ?? null %}
                            {% if stockItem and stockItem.quantite > 0 %}
                                {% set hasStock = true %}
                                {% set prixUnit = prixMap[variante.id] ?? (article.prixBase + (variante.deltaPrix ?? 0)) %}
                                <div style="border:1px solid #e5e7eb;border-radius:0.75rem;padding:0.875rem;margin-bottom:0.75rem;"
                                     x-data="{ qty: 0, prixUnit: {{ prixUnit|number_format(2, '.', '') }} }">
                                    <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.625rem;">
                                        <div style="flex:1;">
                                            <div style="font-weight:600;font-size:0.875rem;color:#111827;">{{ article.nom }}</div>
                                            <div style="font-size:0.75rem;color:#9ca3af;">{{ variante.nom }}</div>
                                        </div>
                                        <div style="font-size:0.8rem;color:#6b7280;">Stock : <strong>{{ stockItem.quantite }}</strong></div>
                                    </div>
                                    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:0.5rem;align-items:end;">
                                        <div>
                                            <label style="display:block;font-size:0.75rem;font-weight:600;color:#374151;margin-bottom:0.25rem;">Qté vendue</label>
                                            <input type="number" name="lignes[{{ stockItem.id }}][qty]"
                                                   min="0" max="{{ stockItem.quantite }}" step="1"
                                                   x-model.number="qty"
                                                   style="width:100%;border:1.5px solid #d1d5db;border-radius:0.5rem;padding:0.4rem 0.5rem;font-size:0.875rem;font-family:inherit;box-sizing:border-box;text-align:center;">
                                        </div>
                                        <div>
                                            <label style="display:block;font-size:0.75rem;font-weight:600;color:#374151;margin-bottom:0.25rem;">Prix estimé/u (€)</label>
                                            <input type="number" name="lignes[{{ stockItem.id }}][prixEstime]"
                                                   step="0.01" min="0"
                                                   value="{{ prixUnit|number_format(2, '.', '') }}"
                                                   readonly
                                                   style="width:100%;border:1.5px solid #e5e7eb;border-radius:0.5rem;padding:0.4rem 0.5rem;font-size:0.875rem;font-family:inherit;box-sizing:border-box;text-align:center;background:#f9fafb;">
                                        </div>
                                        <div>
                                            <label style="display:block;font-size:0.75rem;font-weight:600;color:#374151;margin-bottom:0.25rem;">Prix réel/u (€)</label>
                                            <input type="number" name="lignes[{{ stockItem.id }}][prixReel]"
                                                   step="0.01" min="0"
                                                   :value="qty > 0 ? prixUnit.toFixed(2) : ''"
                                                   style="width:100%;border:1.5px solid #d1d5db;border-radius:0.5rem;padding:0.4rem 0.5rem;font-size:0.875rem;font-family:inherit;box-sizing:border-box;text-align:center;">
                                        </div>
                                    </div>
                                </div>
                            {% endif %}
                        {% endif %}
                    {% endfor %}
                {% endfor %}

                {% if not hasStock %}
                    <p style="text-align:center;color:#9ca3af;padding:2rem 0;font-size:0.875rem;">Aucun article en stock.</p>
                {% endif %}

                <div style="margin-top:1rem;">
                    <label style="display:block;font-size:0.8rem;font-weight:600;color:#374151;margin-bottom:0.35rem;">Note (optionnel)</label>
                    <input type="text" name="note"
                           style="width:100%;border:1.5px solid #d1d5db;border-radius:0.5rem;padding:0.5rem 0.75rem;font-size:0.9rem;font-family:inherit;box-sizing:border-box;"
                           placeholder="Ex : vente samedi marché">
                </div>
                <div style="display:flex;gap:0.75rem;margin-top:1.5rem;">
                    <button type="button" @click="openVente = false"
                            style="flex:1;padding:0.6rem;border-radius:0.625rem;border:1.5px solid #d1d5db;background:#fff;font-weight:600;cursor:pointer;font-size:0.875rem;font-family:inherit;">
                        Annuler
                    </button>
                    <button type="submit" {% if not hasStock %}disabled{% endif %}
                            style="flex:1;padding:0.6rem;border-radius:0.625rem;border:none;background:#111827;color:#fff;font-weight:600;cursor:pointer;font-size:0.875rem;font-family:inherit;">
                        Valider la vente
                    </button>
                </div>
            </form>
        </div>
    </div>

</div>
{% endblock %}
