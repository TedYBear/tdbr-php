{% extends 'admin/base_admin.html.twig' %}

{% block title %}Commande {{ commande.numero }}{% endblock %}
{% block page_title %}Commande {{ commande.numero }}{% endblock %}

{% block body %}
    <div class="grid lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2 space-y-6">
            {# Articles #}
            <div class="card p-6">
                <h2 class="text-xl font-bold mb-4">Articles</h2>
                <div class="space-y-3">
                    {% for article in commande.articles %}
                        <div class="flex gap-4 p-4 bg-gray-50 rounded-lg">
                            {% if article.image %}
                                <img src="{{ article.image }}" alt="{{ article.nom }}" class="w-16 h-16 object-cover rounded">
                            {% else %}
                                <div class="w-16 h-16 bg-gray-200 rounded"></div>
                            {% endif %}
                            <div class="flex-1">
                                <div class="font-semibold">{{ article.nom }}</div>
                                {% if article.variant %}
                                    <div class="text-sm text-gray-600">Variante: {{ article.variant.nom }}</div>
                                {% endif %}
                                <div class="text-sm text-gray-600">Quantité: {{ article.quantity }}</div>
                            </div>
                            <div class="text-right">
                                <div class="font-bold text-primary">{{ article.prix|number_format(2, ',', ' ') }} €</div>
                                <div class="text-sm text-gray-600">Sous-total: {{ (article.prix * article.quantity)|number_format(2, ',', ' ') }} €</div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
                <div class="mt-4 pt-4 border-t flex justify-between text-xl font-bold">
                    <span>Total</span>
                    <span class="text-primary">{{ commande.total|number_format(2, ',', ' ') }} €</span>
                </div>
            </div>

            {# Notes #}
            {% if commande.notes %}
                <div class="card p-6">
                    <h2 class="text-xl font-bold mb-4">Notes du client</h2>
                    <p class="text-gray-700">{{ commande.notes }}</p>
                </div>
            {% endif %}
        </div>

        <div class="lg:col-span-1 space-y-6">
            {# Statut #}
            <div class="card p-6">
                <h2 class="text-xl font-bold mb-4">Statut</h2>
                <form method="post" action="{{ path('admin_commandes_update_status', {id: commande.id}) }}">
                    <select name="statut" class="form-select mb-3" onchange="this.form.submit()">
                        <option value="en_attente" {{ commande.statut == 'en_attente' ? 'selected' : '' }}>En attente</option>
                        <option value="validee" {{ commande.statut == 'validee' ? 'selected' : '' }}>Validée</option>
                        <option value="en_cours" {{ commande.statut == 'en_cours' ? 'selected' : '' }}>En cours</option>
                        <option value="expediee" {{ commande.statut == 'expediee' ? 'selected' : '' }}>Expédiée</option>
                        <option value="livree" {{ commande.statut == 'livree' ? 'selected' : '' }}>Livrée</option>
                        <option value="annulee" {{ commande.statut == 'annulee' ? 'selected' : '' }}>Annulée</option>
                    </select>
                </form>
            </div>

            {# Client #}
            <div class="card p-6">
                <h2 class="text-xl font-bold mb-4">Client</h2>
                <div class="space-y-2 text-sm">
                    <div><strong>Nom:</strong> {{ commande.client.prenom }} {{ commande.client.nom }}</div>
                    <div><strong>Email:</strong> {{ commande.client.email }}</div>
                    <div><strong>Téléphone:</strong> {{ commande.client.telephone }}</div>
                </div>
            </div>

            {# Livraison #}
            <div class="card p-6">
                <h2 class="text-xl font-bold mb-4">Livraison</h2>
                <div class="text-sm space-y-1">
                    <div>{{ commande.adresseLivraison.adresse }}</div>
                    {% if commande.adresseLivraison.complementAdresse %}
                        <div>{{ commande.adresseLivraison.complementAdresse }}</div>
                    {% endif %}
                    <div>{{ commande.adresseLivraison.codePostal }} {{ commande.adresseLivraison.ville }}</div>
                    <div class="font-semibold">{{ commande.adresseLivraison.pays }}</div>
                </div>
            </div>

            {# Paiement #}
            <div class="card p-6">
                <h2 class="text-xl font-bold mb-4">Paiement</h2>
                <div class="text-sm">
                    <strong>Mode:</strong> {{ commande.modePaiement|capitalize }}
                </div>
            </div>

            {# Printful #}
            {% if commande.printfulOrderId %}
                <div class="card p-6">
                    <h2 class="text-xl font-bold mb-3">Printful</h2>
                    <div class="text-sm space-y-2">
                        <div>
                            <span class="text-gray-500">ID commande :</span>
                            <span class="font-mono font-semibold ml-1">{{ commande.printfulOrderId }}</span>
                        </div>
                        <div class="inline-flex items-center gap-1.5 px-2 py-1 rounded-full bg-amber-50 text-amber-700 text-xs font-semibold">
                            Brouillon — à confirmer sur Printful
                        </div>
                    </div>
                    <a href="https://www.printful.com/dashboard/orders" target="_blank" rel="noopener"
                       class="mt-3 inline-flex items-center gap-1.5 text-xs text-primary hover:underline">
                        Ouvrir Printful
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                        </svg>
                    </a>
                </div>
            {% endif %}

            {# Dates #}
            <div class="card p-6">
                <h2 class="text-xl font-bold mb-4">Dates</h2>
                <div class="space-y-2 text-sm">
                    <div><strong>Créée le:</strong><br>{{ commande.createdAt|date('d/m/Y à H:i') }}</div>
                    <div><strong>Modifiée le:</strong><br>{{ commande.updatedAt ? commande.updatedAt|date('d/m/Y à H:i') : '-' }}</div>
                </div>
            </div>

            {# Facture #}
            <a href="{{ path('admin_commandes_facture', {id: commande.id}) }}" target="_blank"
               class="flex items-center justify-center gap-2 w-full px-4 py-2 bg-gray-900 text-white rounded-lg hover:bg-gray-700 transition text-sm font-semibold">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                Voir la facture
            </a>

            {# Supprimer #}
            <form method="post" action="{{ path('admin_commandes_delete', {id: commande.id}) }}"
                  onsubmit="window.confirmForm(event, this, 'Supprimer définitivement cette commande ?')">
                <button type="submit" class="w-full px-4 py-2 text-red-600 border border-red-200 rounded-lg hover:bg-red-50 transition text-sm">
                    Supprimer cette commande
                </button>
            </form>
        </div>
    </div>
{% endblock %}
