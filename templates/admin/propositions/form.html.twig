{% extends 'admin/base_admin.html.twig' %}

{% block title %}{{ proposition ? 'Modifier la proposition' : 'Nouvelle proposition' }}{% endblock %}
{% block page_title %}{{ proposition ? 'Modifier la proposition' : 'Nouvelle proposition commerciale' }}{% endblock %}
{% block page_subtitle %}
    {% if devis %}
        <p class="text-sm text-gray-500 mt-1">
            Liée à la demande <a href="{{ path('admin_devis_detail', {id: devis.id}) }}" class="text-primary hover:underline">#{{ devis.id }} — {{ devis.nom }}</a>
        </p>
    {% endif %}
{% endblock %}

{% block body %}
<div class="grid lg:grid-cols-3 gap-8">
    {# Formulaire principal #}
    <div class="lg:col-span-2">
        <form method="post" class="space-y-6" x-data="propositionForm()">

            {# Client #}
            <div class="card p-6 space-y-5">
                <h2 class="font-heading text-base font-bold text-gray-700">Client</h2>

                {# Autocomplete utilisateurs existants #}
                <div class="form-group" x-data="clientSearch()" x-init="init()">
                    <label>Rechercher un utilisateur existant</label>
                    <div class="relative">
                        <input type="text" class="form-input" placeholder="Nom ou email..."
                               x-model="query"
                               @input.debounce.300ms="search()"
                               @keydown.escape="results = []"
                               autocomplete="off">
                        <div x-show="results.length > 0"
                             class="absolute z-50 w-full bg-white border border-gray-200 rounded-lg shadow-lg mt-1 max-h-48 overflow-y-auto">
                            <template x-for="user in results" :key="user.id">
                                <button type="button"
                                        @click="select(user)"
                                        class="w-full text-left px-4 py-2.5 hover:bg-gray-50 border-b border-gray-100 last:border-0">
                                    <span class="font-medium text-sm" x-text="user.fullName || user.email"></span>
                                    <span class="text-xs text-gray-500 ml-1" x-text="user.fullName ? '— ' + user.email : ''"></span>
                                </button>
                            </template>
                        </div>
                    </div>
                    <p class="text-xs text-gray-400 mt-1">Sélectionner remplit automatiquement les champs ci-dessous.</p>
                </div>

                <div class="form-group">
                    <label>Email du client *</label>
                    <input type="email" name="clientEmail" required class="form-input" id="clientEmail"
                           value="{{ proposition ? proposition.clientEmail : (devis ? devis.email : '') }}"
                           placeholder="client@exemple.fr">
                </div>

                <div class="form-group">
                    <label>Nom du client</label>
                    <input type="text" name="clientNom" class="form-input" id="clientNom"
                           value="{{ proposition ? proposition.clientNom : (devis ? devis.nom : '') }}"
                           placeholder="Prénom Nom">
                </div>
            </div>

            <script>
            function clientSearch() {
                return {
                    query: '',
                    results: [],
                    init() {},
                    async search() {
                        if (this.query.length < 2) { this.results = []; return; }
                        try {
                            const r = await fetch(`{{ path('admin_propositions_clients_search') }}?q=${encodeURIComponent(this.query)}`);
                            this.results = await r.json();
                        } catch(e) { this.results = []; }
                    },
                    select(user) {
                        document.getElementById('clientEmail').value = user.email;
                        document.getElementById('clientNom').value = user.fullName;
                        this.query = '';
                        this.results = [];
                    }
                };
            }
            </script>

            {# 1 - Coût de création du design (optionnel) #}
            <div class="card p-6 space-y-4">
                <div class="flex items-center justify-between">
                    <h2 class="font-heading text-base font-bold text-gray-700">
                        1 — Coût de création du design
                        <span class="text-xs font-normal text-gray-400 ml-1">(optionnel)</span>
                    </h2>
                </div>
                <div class="form-group">
                    <label>Montant (€)</label>
                    <input type="number" name="coutDesign" class="form-input" step="0.01" min="0"
                           x-model="coutDesign"
                           value="{{ proposition and proposition.coutDesign is not null ? proposition.coutDesign : '' }}"
                           placeholder="0.00">
                    <p class="text-xs text-gray-500 mt-1">Création graphique et adaptation aux différents supports.</p>
                </div>
            </div>

            {# 2 - Prix public (requis) #}
            <div class="card p-6 space-y-4">
                <h2 class="font-heading text-base font-bold text-gray-700">
                    2 — Prix public
                    <span class="text-xs font-normal text-red-400 ml-1">*</span>
                </h2>
                <div class="form-group">
                    <label>Description du contenu *</label>
                    <textarea name="description" required class="form-input font-mono text-sm" rows="8"
                              placeholder="Articles, quantités, personnalisations, délais...">{{ proposition ? proposition.description : '' }}</textarea>
                    <p class="text-xs text-gray-500 mt-1">Affiché dans l'email et sur la page client.</p>
                </div>
                <div class="form-group">
                    <label>Montant (€) *</label>
                    <input type="number" name="prixPublic" required class="form-input" step="0.01" min="0"
                           x-model="prixPublic"
                           value="{{ proposition ? proposition.prixPublic : '' }}"
                           placeholder="0.00">
                </div>
            </div>

            {# 3 - Frais de manutention (optionnel) #}
            <div class="card p-6 space-y-4">
                <h2 class="font-heading text-base font-bold text-gray-700">
                    3 — Frais de manutention
                    <span class="text-xs font-normal text-gray-400 ml-1">(optionnel)</span>
                </h2>
                <div class="form-group">
                    <label>Montant (€)</label>
                    <input type="number" name="fraisManutention" class="form-input" step="0.01" min="0"
                           x-model="fraisManutention"
                           value="{{ proposition and proposition.fraisManutention is not null ? proposition.fraisManutention : '' }}"
                           placeholder="0.00">
                </div>
            </div>

            {# 4 - Ristourne (optionnel) #}
            <div class="card p-6 space-y-4">
                <h2 class="font-heading text-base font-bold text-gray-700">
                    4 — Ristourne
                    <span class="text-xs font-normal text-gray-400 ml-1">(optionnel)</span>
                </h2>
                <div class="form-group">
                    <label>Montant à déduire (€)</label>
                    <input type="number" name="ristourne" class="form-input" step="0.01" min="0"
                           x-model="ristourne"
                           value="{{ proposition and proposition.ristourne is not null ? proposition.ristourne : '' }}"
                           placeholder="0.00">
                </div>
            </div>

            {# Total calculé #}
            <div class="card p-5 bg-gray-50 flex items-center justify-between">
                <span class="text-sm font-medium text-gray-600">Total TTC (calculé)</span>
                <span class="text-2xl font-black text-gray-900" x-text="formatTotal()"></span>
            </div>

            <div class="flex gap-3 flex-wrap">
                <button type="submit" name="action" value="save" class="btn-outline">
                    Enregistrer en brouillon
                </button>
                <button type="submit" name="action" value="send"
                        class="btn-primary"
                        onclick="return confirm('Envoyer la proposition par email à ' + document.querySelector('[name=clientEmail]').value + ' ?')">
                    Envoyer par email
                </button>
                <a href="{{ path('admin_propositions') }}" class="btn-outline">Annuler</a>
            </div>

        </form>

        <script>
        function propositionForm() {
            return {
                coutDesign: parseFloat(document.querySelector('[name=coutDesign]')?.value) || 0,
                prixPublic: parseFloat(document.querySelector('[name=prixPublic]')?.value) || 0,
                fraisManutention: parseFloat(document.querySelector('[name=fraisManutention]')?.value) || 0,
                ristourne: parseFloat(document.querySelector('[name=ristourne]')?.value) || 0,
                get total() {
                    return (this.coutDesign || 0) + (this.prixPublic || 0) + (this.fraisManutention || 0) - (this.ristourne || 0);
                },
                formatTotal() {
                    return this.total.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' €';
                }
            };
        }
        </script>
    </div>

    {# Sidebar infos #}
    <div class="space-y-6">

        {% if proposition %}
            {# Statut #}
            <div class="card p-6">
                <h2 class="font-heading text-lg font-bold mb-3">Statut</h2>
                {% if proposition.statut == 'brouillon' %}
                    <span class="px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-600">Brouillon</span>
                {% elseif proposition.statut == 'envoyee' %}
                    <span class="px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-700">Envoyée</span>
                {% elseif proposition.statut == 'acceptee' %}
                    <span class="px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-700">Acceptée</span>
                {% elseif proposition.statut == 'en_attente_virement' %}
                    <span class="px-3 py-1 rounded-full text-sm font-medium bg-amber-100 text-amber-700">Virement en attente</span>
                {% elseif proposition.statut == 'payee' %}
                    <span class="px-3 py-1 rounded-full text-sm font-medium bg-purple-100 text-purple-700">Payée</span>
                {% endif %}

                {% if proposition.createdAt %}
                    <p class="text-xs text-gray-500 mt-3">Créée le {{ proposition.createdAt|date('d/m/Y à H:i') }}</p>
                {% endif %}
                {% if proposition.updatedAt %}
                    <p class="text-xs text-gray-500">Mise à jour le {{ proposition.updatedAt|date('d/m/Y à H:i') }}</p>
                {% endif %}
            </div>

            {# Lien public #}
            <div class="card p-6">
                <h2 class="font-heading text-lg font-bold mb-3">Lien de validation</h2>
                <p class="text-xs text-gray-500 mb-2">Page client pour accepter et payer :</p>
                <input type="text" readonly class="form-input text-xs font-mono bg-gray-50"
                       value="{{ url('proposition_view', {token: proposition.token}) }}"
                       onclick="this.select()">
                <p class="text-xs text-gray-400 mt-1">Cliquer pour sélectionner</p>
            </div>

            {% if proposition.commande %}
                <div class="card p-6">
                    <h2 class="font-heading text-lg font-bold mb-3">Commande associée</h2>
                    <a href="{{ path('admin_commande_detail', {id: proposition.commande.id}) }}"
                       class="text-primary hover:underline font-medium">
                        {{ proposition.commande.numero }}
                    </a>
                    <p class="text-xs text-gray-500 mt-1">{{ proposition.commande.statut }}</p>
                    {% if proposition.statut == 'payee' %}
                        <a href="{{ path('admin_propositions_facture', {id: proposition.id}) }}"
                           class="mt-3 w-full flex items-center justify-center gap-2 px-4 py-2 border border-gray-300 rounded-lg text-sm hover:bg-gray-50 transition">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                            Voir la facture
                        </a>
                    {% endif %}
                </div>
            {% endif %}

            {# Marquer comme payée (virement) #}
            {% if proposition.statut == 'en_attente_virement' %}
                <div class="card p-6 bg-amber-50 border border-amber-200">
                    <h2 class="font-heading text-base font-bold mb-2 text-amber-800">Virement en attente</h2>
                    <p class="text-xs text-amber-700 mb-3">
                        IBAN : <span class="font-mono font-bold">FR76 1695 8000 0122 5925 2066 395</span><br>
                        Ref : <span class="font-mono">{{ proposition.token|slice(0,12)|upper }}</span>
                    </p>
                    <form method="post" action="{{ path('admin_propositions_marquer_payee', {id: proposition.id}) }}"
                          onsubmit="return confirm('Confirmer la réception du virement et marquer comme payée ?')">
                        <button type="submit" class="w-full px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 font-semibold text-sm">
                            Virement reçu — Marquer payée
                        </button>
                    </form>
                </div>
            {% endif %}

            {# Renvoyer l'email #}
            {% if proposition.statut in ['envoyee', 'brouillon'] %}
                <form method="post" action="{{ path('admin_propositions_send', {id: proposition.id}) }}"
                      onsubmit="return confirm('Renvoyer la proposition par email ?')">
                    <button type="submit" class="w-full btn-outline">
                        {{ proposition.statut == 'envoyee' ? 'Renvoyer l\'email' : 'Envoyer l\'email' }}
                    </button>
                </form>
            {% endif %}

            {# Supprimer #}
            <form method="post" action="{{ path('admin_propositions_delete', {id: proposition.id}) }}"
                  onsubmit="window.confirmForm(event, this, 'Supprimer définitivement cette proposition ?')">
                <button type="submit" class="w-full px-4 py-2 text-red-600 border border-red-200 rounded-lg hover:bg-red-50 transition text-sm">
                    Supprimer
                </button>
            </form>
        {% else %}
            <div class="card p-6">
                <h2 class="font-heading text-lg font-bold mb-2">Astuce</h2>
                <p class="text-sm text-gray-600">
                    Remplissez la description et le prix, puis choisissez d'enregistrer en brouillon ou d'envoyer directement l'email au client.
                </p>
                <p class="text-sm text-gray-600 mt-2">
                    Le client recevra un lien unique pour visualiser et valider la proposition.
                </p>
            </div>
        {% endif %}

    </div>
</div>
{% endblock %}
