<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Espace dépôt-vente{% endblock %} - TDBR</title>
    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('build/app.3c391010.css') }}">
    {% endblock %}
    <style>[x-cloak]{display:none!important}</style>
</head>
<body class="bg-gray-50 min-h-screen">

    {# Navbar #}
    <header style="background:#fff;border-bottom:1px solid #e5e7eb;position:sticky;top:0;z-index:100;">
        <div class="container mx-auto px-4 h-16 flex items-center justify-between">
            <a href="{{ path('depot_vente_dashboard') }}" class="flex items-center gap-3">
                <img src="{{ asset('images/logo.png') }}" alt="TDBR" class="h-9" onerror="this.style.display='none'">
                <span class="font-heading font-bold text-gray-800 text-lg">Espace dépôt-vente</span>
            </a>

            <div class="flex items-center gap-4">
                <span class="text-sm text-gray-500 hidden sm:block">
                    {{ app.user.prenom }} {{ app.user.nom }}
                </span>
                <a href="{{ path('logout') }}"
                   class="text-sm font-medium text-gray-600 hover:text-red-600 transition flex items-center gap-1.5">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                    </svg>
                    Déconnexion
                </a>
            </div>
        </div>
    </header>

    {# Flash messages #}
    {% include 'layout/flash_messages.html.twig' %}

    {# Content #}
    <main class="container mx-auto px-4 py-8">
        {% block body %}{% endblock %}
    </main>

    {% block javascripts %}
        <script src="{{ asset('build/runtime.f073a35a.js') }}"></script>
        <script src="{{ asset('build/705.31b65463.js') }}"></script>
        <script src="{{ asset('build/app.579e6744.js') }}"></script>
    {% endblock %}
</body>
</html>
