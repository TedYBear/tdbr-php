{% extends 'depot_vente/base_depot_vente.html.twig' %}

{% block title %}Tableau de bord{% endblock %}

{% block body %}
    {# Header #}
    <div class="mb-8">
        <h1 class="font-heading text-3xl font-bold text-gray-900">
            Bonjour {{ app.user.prenom }} !
        </h1>
        <p class="text-gray-500 mt-1">Bienvenue dans votre espace dépôt-vente TDBR.</p>
    </div>

    {# Cartes stats (placeholders) #}
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
        <div class="card p-6">
            <p class="text-sm text-gray-500 mb-1">Articles en dépôt</p>
            <p class="text-3xl font-bold text-gray-900">—</p>
        </div>
        <div class="card p-6">
            <p class="text-sm text-gray-500 mb-1">Ventes ce mois</p>
            <p class="text-3xl font-bold text-gray-900">—</p>
        </div>
        <div class="card p-6">
            <p class="text-sm text-gray-500 mb-1">Chiffre d'affaires</p>
            <p class="text-3xl font-bold text-gray-900">—</p>
        </div>
    </div>

    {# Section articles #}
    <div class="card overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100">
            <h2 class="font-semibold text-gray-800">Articles en dépôt</h2>
        </div>
        <div class="px-6 py-12 text-center text-gray-400">
            <svg class="w-10 h-10 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z"/>
            </svg>
            <p class="text-sm">Aucun article pour le moment.</p>
        </div>
    </div>
{% endblock %}
