{% extends 'emails/base.html.twig' %}

{% block header_title %}Commande Confirmée{% endblock %}

{% block content %}
    <h2 style="color: #2C2416; margin-top: 0;">Merci pour votre commande !</h2>

    <p style="font-size: 16px; line-height: 1.6; color: #333;">
        Bonjour <strong>{{ commande.client.prenom }} {{ commande.client.nom }}</strong>,
    </p>

    <p style="font-size: 16px; line-height: 1.6; color: #333;">
        Nous avons bien reçu votre commande <strong>{{ commande.numero }}</strong> et nous vous en remercions ! 🎁
    </p>

    <div style="background-color: #F5E6D3; padding: 20px; border-radius: 8px; margin: 20px 0;">
        <h3 style="margin-top: 0; color: #8B7355;">Récapitulatif de votre commande</h3>

        {% set sousTotal = 0 %}
        {% for article in commande.articles %}
            {% set ligneTotal = article.prix * article.quantity %}
            {% set sousTotal = sousTotal + ligneTotal %}
            <div style="padding: 10px 0; border-bottom: 1px solid #D4AF7A;">
                <strong>{{ article.nom }}</strong>
                {% if article.variant %}
                    <br><span style="font-size: 14px; color: #666;">Variante: {{ article.variant.nom }}</span>
                {% endif %}
                <br>Quantité: {{ article.quantity }} × {{ article.prix|number_format(2, ',', ' ') }} €
                = <strong>{{ ligneTotal|number_format(2, ',', ' ') }} €</strong>
            </div>
        {% endfor %}

        {% set fraisLivraison = commande.total - sousTotal + commande.reduction %}
        <table style="width:100%;border-collapse:collapse;margin-top:12px;">
            <tr>
                <td style="padding:6px 0;border-bottom:1px solid #D4AF7A;font-size:14px;color:#666;">Articles</td>
                <td style="padding:6px 0;border-bottom:1px solid #D4AF7A;font-size:14px;color:#666;text-align:right;">{{ sousTotal|number_format(2, ',', ' ') }} €</td>
            </tr>
            <tr>
                <td style="padding:6px 0;border-bottom:1px solid #D4AF7A;font-size:14px;color:#666;">Livraison</td>
                <td style="padding:6px 0;border-bottom:1px solid #D4AF7A;font-size:14px;color:#666;text-align:right;">{% if fraisLivraison <= 0 %}Gratuite{% else %}{{ fraisLivraison|number_format(2, ',', ' ') }} €{% endif %}</td>
            </tr>
            {% if commande.reduction > 0 %}
            <tr>
                <td style="padding:6px 0;border-bottom:1px solid #D4AF7A;font-size:14px;font-weight:600;color:#15803d;">Réduction</td>
                <td style="padding:6px 0;border-bottom:1px solid #D4AF7A;font-size:14px;font-weight:600;color:#15803d;text-align:right;">- {{ commande.reduction|number_format(2, ',', ' ') }} €</td>
            </tr>
            {% endif %}
            <tr>
                <td style="padding-top:12px;font-size:18px;font-weight:bold;color:#8B7355;">Total</td>
                <td style="padding-top:12px;font-size:18px;font-weight:bold;color:#8B7355;text-align:right;">{{ commande.total|number_format(2, ',', ' ') }} €</td>
            </tr>
        </table>
    </div>

    <h3 style="color: #8B7355;">Mode de livraison</h3>
    <p style="font-size: 14px; line-height: 1.6; color: #333;">
        <strong>{{ commande.modeLivraison.label }}</strong>
        {% if commande.modeLivraison.prix > 0 %}
            — {{ commande.modeLivraison.prix|number_format(2, ',', ' ') }} €
        {% else %}
            — Offert
        {% endif %}
        {% if commande.modeLivraison.type == 'relais' %}
            <br>Point relais : <strong>{{ commande.modeLivraison.pointRelaisNom }}</strong>
            <br>{{ commande.modeLivraison.pointRelaisAdresse }}
        {% endif %}
    </p>

    <h3 style="color: #8B7355;">Adresse de livraison</h3>
    <p style="font-size: 14px; line-height: 1.6; color: #333;">
        {{ commande.adresseLivraison.adresse }}<br>
        {% if commande.adresseLivraison.complementAdresse %}
            {{ commande.adresseLivraison.complementAdresse }}<br>
        {% endif %}
        {{ commande.adresseLivraison.codePostal }} {{ commande.adresseLivraison.ville }}<br>
        {{ commande.adresseLivraison.pays }}
    </p>

    <h3 style="color: #8B7355;">Mode de paiement</h3>
    <p style="font-size: 14px; line-height: 1.6; color: #333;">
        {{ commande.modePaiement|capitalize }}
    </p>

    {% if confirmationUrl %}
    <div style="text-align: center; margin: 30px 0;">
        <a href="{{ confirmationUrl }}" style="display:inline-block;background-color:#8B7355;color:#fff;padding:14px 32px;border-radius:8px;text-decoration:none;font-weight:700;font-size:16px;">
            Voir ma commande
        </a>
    </div>
    {% endif %}

    <p style="font-size: 14px; line-height: 1.6; color: #666; margin-top: 30px;">
        Nous préparons votre commande avec soin. Vous recevrez un email lorsqu'elle sera expédiée.
    </p>

    <p style="font-size: 16px; line-height: 1.6; color: #333; font-weight: 600;">
        À très bientôt !<br>
        L'équipe TDBR
    </p>
{% endblock %}
