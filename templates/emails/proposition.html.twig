{% extends 'emails/base.html.twig' %}

{% block header_title %}Proposition Commerciale{% endblock %}

{% block content %}
    <h2 style="color: #2C2416; margin-top: 0;">Votre proposition sur-mesure</h2>

    <p style="font-size: 16px; line-height: 1.6; color: #333;">
        {% if proposition.clientNom %}Bonjour <strong>{{ proposition.clientNom }}</strong>,{% else %}Bonjour,{% endif %}
    </p>

    {% if messagePersonnel %}
    <div style="font-size: 16px; line-height: 1.7; color: #333; white-space: pre-line; margin-bottom: 20px; padding: 16px 20px; background: #fdfaf6; border-left: 3px solid #D4AF7A; border-radius: 0 6px 6px 0;">{{ messagePersonnel }}</div>
    {% else %}
    <p style="font-size: 16px; line-height: 1.6; color: #333;">
        Nous avons le plaisir de vous adresser notre proposition commerciale pour votre projet sur-mesure.
    </p>
    {% endif %}

    <div style="background-color: #F5E6D3; padding: 20px; border-radius: 8px; margin: 20px 0;">
        <h3 style="margin-top: 0; color: #8B7355;">Détail de la proposition</h3>

        {% if proposition.description %}
        <div style="font-size: 15px; line-height: 1.7; color: #333; white-space: pre-line; margin-bottom: 16px;">{{ proposition.description }}</div>
        {% endif %}

        <table style="width: 100%; border-collapse: collapse; font-size: 14px; margin-bottom: 12px;">
            {% if proposition.coutDesign is not null and proposition.coutDesign > 0 %}
            <tr>
                <td style="padding: 6px 0; color: #555;">Création du design et adaptation aux supports</td>
                <td style="padding: 6px 0; text-align: right; font-weight: 600; color: #333;">{{ proposition.coutDesign|number_format(2, ',', ' ') }} €</td>
            </tr>
            {% endif %}
            <tr>
                <td style="padding: 6px 0; color: #555;">Prix public</td>
                <td style="padding: 6px 0; text-align: right; font-weight: 600; color: #333;">{{ proposition.prixPublic|number_format(2, ',', ' ') }} €</td>
            </tr>
            {% if proposition.fraisManutention is not null and proposition.fraisManutention > 0 %}
            <tr>
                <td style="padding: 6px 0; color: #555;">Frais de manutention</td>
                <td style="padding: 6px 0; text-align: right; font-weight: 600; color: #333;">{{ proposition.fraisManutention|number_format(2, ',', ' ') }} €</td>
            </tr>
            {% endif %}
            {% if proposition.ristourne is not null and proposition.ristourne > 0 %}
            <tr>
                <td style="padding: 6px 0; color: #15803d;">Ristourne</td>
                <td style="padding: 6px 0; text-align: right; font-weight: 600; color: #15803d;">− {{ proposition.ristourne|number_format(2, ',', ' ') }} €</td>
            </tr>
            {% endif %}
            <tr style="border-top: 2px solid #D4AF7A;">
                <td style="padding: 10px 0 4px; font-size: 18px; font-weight: bold; color: #8B7355;">Total TTC</td>
                <td style="padding: 10px 0 4px; text-align: right; font-size: 22px; font-weight: bold; color: #8B7355;">{{ proposition.prixTotal|number_format(2, ',', ' ') }} €</td>
            </tr>
        </table>

        <p style="font-size: 12px; color: #999; margin: 0;">TVA non applicable – art. 293 B du CGI</p>
    </div>

    <p style="font-size: 15px; line-height: 1.6; color: #555;">
        La proposition commerciale détaillée est jointe à cet email en pièce jointe PDF.<br>
        Pour valider et procéder au paiement, cliquez sur le bouton ci-dessous :
    </p>

    <div style="text-align: center; margin: 30px 0;">
        <a href="{{ publicUrl }}" class="button" style="display:inline-block;padding:16px 36px;background:linear-gradient(135deg,#8B7355 0%,#D4AF7A 100%);color:#fff;text-decoration:none;border-radius:8px;font-weight:700;font-size:16px;">
            Voir et valider la proposition
        </a>
    </div>

    <p style="font-size: 13px; line-height: 1.6; color: #999;">
        Ou copiez ce lien dans votre navigateur :<br>
        <a href="{{ publicUrl }}" style="color:#8B7355;word-break:break-all;">{{ publicUrl }}</a>
    </p>

    <p style="font-size: 14px; line-height: 1.6; color: #666; margin-top: 30px;">
        Une question ? <a href="{{ contactUrl }}" style="color:#8B7355;font-weight:600;">Contactez-nous via le formulaire</a>
    </p>

    <p style="font-size: 16px; line-height: 1.6; color: #333; font-weight: 600;">
        À très bientôt !<br>
        L'équipe TDBR
    </p>
{% endblock %}
