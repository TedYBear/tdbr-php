{% extends 'emails/base.html.twig' %}

{% block header_title %}Proposition Commerciale{% endblock %}

{% block content %}
    <h2 style="color: #2C2416; margin-top: 0;">Votre proposition sur-mesure</h2>

    <p style="font-size: 16px; line-height: 1.6; color: #333;">
        {% if proposition.clientNom %}Bonjour <strong>{{ proposition.clientNom }}</strong>,{% else %}Bonjour,{% endif %}
    </p>

    <p style="font-size: 16px; line-height: 1.6; color: #333;">
        Nous avons le plaisir de vous adresser notre proposition commerciale pour votre projet sur-mesure.
    </p>

    <div style="background-color: #F5E6D3; padding: 20px; border-radius: 8px; margin: 20px 0;">
        <h3 style="margin-top: 0; color: #8B7355;">Détail de la proposition</h3>
        <div style="font-size: 15px; line-height: 1.7; color: #333; white-space: pre-line;">{{ proposition.description }}</div>
        <div style="margin-top: 16px; padding-top: 16px; border-top: 1px solid #D4AF7A;">
            <span style="font-size: 20px; font-weight: bold; color: #8B7355;">
                Total : {{ proposition.prixTotal|number_format(2, ',', ' ') }} €
            </span>
            <span style="font-size: 13px; color: #666; margin-left: 8px;">(TVA non applicable – art. 293 B du CGI)</span>
        </div>
    </div>

    <p style="font-size: 15px; line-height: 1.6; color: #555;">
        Pour valider cette proposition et procéder au paiement, cliquez sur le bouton ci-dessous :
    </p>

    <div style="text-align: center; margin: 30px 0;">
        <a href="{{ publicUrl }}" class="button" style="display:inline-block;padding:16px 36px;background:linear-gradient(135deg,#8B7355 0%,#D4AF7A 100%);color:#fff;text-decoration:none;border-radius:8px;font-weight:700;font-size:16px;">
            Voir et valider la proposition
        </a>
    </div>

    <p style="font-size: 13px; line-height: 1.6; color: #999;">
        Ou copiez ce lien dans votre navigateur :<br>
        <a href="{{ publicUrl }}" style="color:#8B7355;word-break:break-all;">{{ publicUrl }}</a>
    </p>

    <p style="font-size: 14px; line-height: 1.6; color: #666; margin-top: 30px;">
        N'hésitez pas à nous contacter si vous avez des questions.
    </p>

    <p style="font-size: 16px; line-height: 1.6; color: #333; font-weight: 600;">
        À très bientôt !<br>
        L'équipe TDBR
    </p>
{% endblock %}
