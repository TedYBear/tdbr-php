{# Navbar Component #}
<style>
.nav-menu-link { border-radius: 0.5rem; padding: 0.375rem 0.75rem; transition: background-color 0.15s, color 0.15s; }
.nav-menu-link:hover { background-color: #fffbeb; }
</style>
<nav class="bg-white shadow-md sticky top-0 z-50" x-data="{ mobileOpen: false }">
    <div class="container mx-auto px-4 py-3 md:py-4">
        <div class="flex items-center justify-between">

            {# Logo #}
            <a href="{{ path('home') }}" class="flex items-center space-x-2">
                <img src="{{ asset('build/images/TDBR.png') }}" alt="TDBR Logo" class="h-10 md:h-12 w-auto">
                <span class="font-heading text-xl md:text-2xl font-bold gradient-text">TDBR</span>
            </a>

            {# Menu Desktop (md+) #}
            <div class="hidden md:flex items-center space-x-1">
                <a href="{{ path('home') }}" class="nav-menu-link hover:text-primary">Accueil</a>
                <a href="{{ path('presentation') }}" class="nav-menu-link hover:text-primary">Présentation</a>
                <a href="{{ path('catalogue', {}) }}" class="nav-menu-link hover:text-primary">Catalogue</a>
                <a href="{{ path('avis_liste') }}" class="nav-menu-link hover:text-primary">Vos retours</a>
                <a href="{{ path('devis') }}" class="nav-menu-link hover:text-primary">Sur-mesure</a>
                <a href="{{ path('contact', {}) }}" class="nav-menu-link hover:text-primary">Contact</a>
            </div>

            {# Actions (toujours visibles) #}
            <div class="flex items-center space-x-2">
                {# Réseaux sociaux #}
                <a href="https://www.instagram.com/tdbrlaboutique/" target="_blank" rel="noopener" class="p-2 hover:text-primary transition" aria-label="Instagram">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"/>
                    </svg>
                </a>
                <a href="https://www.facebook.com/profile.php?id=61588562085687" target="_blank" rel="noopener" class="p-2 hover:text-primary transition" aria-label="Facebook">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
                    </svg>
                </a>

                {# Panier #}
                <a href="{{ path('panier', {}) }}" class="relative p-2 hover:text-primary transition">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
                    </svg>
                    {% set cartCount = app.request.attributes.get('_cart_count', 0) %}
                    <span data-cart-count class="absolute top-0 right-0 bg-secondary text-white text-xs rounded-full w-5 h-5 flex items-center justify-center {{ cartCount > 0 ? '' : 'hidden' }}">
                        {{ cartCount }}
                    </span>
                </a>

                {# User Menu (desktop uniquement) #}
                {% if app.user %}
                    <div class="relative hidden md:block" x-data="{ open: false }">
                        <button @click="open = !open" @click.away="open = false" class="flex items-center gap-2 hover:text-primary transition">
                            <div class="w-9 h-9 bg-gradient-to-br from-primary to-secondary rounded-full flex items-center justify-center text-white text-sm font-bold">
                                {{ app.user.prenom|first }}{{ app.user.nom|first }}
                            </div>
                        </button>
                        <div x-show="open" x-transition class="absolute right-0 mt-2 w-48 bg-white shadow-lg rounded-lg py-2">
                            <a href="{{ path('profil', {}) }}" class="block px-4 py-2 hover:bg-gray-100">Mon profil</a>
                            {% if is_granted('ROLE_ADMIN') %}
                                <a href="{{ path('admin_dashboard', {}) }}" class="block px-4 py-2 hover:bg-gray-100">Administration</a>
                            {% endif %}
                            {% if is_granted('ROLE_DEPOT_VENTE') %}
                                <a href="{{ path('depot_vente_dashboard') }}" class="block px-4 py-2 hover:bg-amber-50 text-amber-700">Espace dépôt-vente</a>
                            {% endif %}
                            <a href="{{ path('logout', {}) }}" class="block px-4 py-2 hover:bg-gray-100 text-red-600">Déconnexion</a>
                        </div>
                    </div>
                {% else %}
                    <div class="hidden md:flex items-center space-x-3">
                        <a href="{{ path('connexion', {}) }}" class="hover:text-primary transition text-sm">Connexion</a>
                        <a href="{{ path('inscription', {}) }}" class="btn-primary text-sm">S'inscrire</a>
                    </div>
                {% endif %}

                {# Burger (mobile uniquement) #}
                <button class="md:hidden p-2 rounded-lg hover:bg-gray-100 transition"
                        @click="mobileOpen = !mobileOpen"
                        aria-label="Menu">
                    <svg x-show="!mobileOpen" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                    <svg x-show="mobileOpen" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
        </div>
    </div>

    {# Drawer mobile #}
    <div x-show="mobileOpen" x-cloak class="md:hidden border-t border-gray-100 bg-white shadow-lg">
        <div class="px-4 py-3 space-y-1">
            <a href="{{ path('home') }}" class="block px-3 py-3 rounded-xl hover:bg-gray-50 font-medium" @click="mobileOpen = false">Accueil</a>
            <a href="{{ path('presentation') }}" class="block px-3 py-3 rounded-xl hover:bg-gray-50 font-medium" @click="mobileOpen = false">Présentation</a>
            <a href="{{ path('catalogue', {}) }}" class="block px-3 py-3 rounded-xl hover:bg-gray-50 font-medium" @click="mobileOpen = false">Catalogue</a>

<a href="{{ path('avis_liste') }}" class="block px-3 py-3 rounded-xl hover:bg-gray-50 font-medium" @click="mobileOpen = false">Vos retours</a>
            <a href="{{ path('devis') }}" class="block px-3 py-3 rounded-xl hover:bg-gray-50 font-medium" @click="mobileOpen = false">Sur-mesure</a>
            <a href="{{ path('contact', {}) }}" class="block px-3 py-3 rounded-xl hover:bg-gray-50 font-medium" @click="mobileOpen = false">Contact</a>

            {# Compte #}
            <div class="border-t border-gray-100 pt-3 mt-1 space-y-1">
                {% if app.user %}
                    <div class="px-3 py-2 text-sm text-gray-500 font-medium">{{ app.user.prenom }} {{ app.user.nom }}</div>
                    <a href="{{ path('profil', {}) }}" class="block px-3 py-3 rounded-xl hover:bg-gray-50" @click="mobileOpen = false">Mon profil</a>
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('admin_dashboard', {}) }}" class="block px-3 py-3 rounded-xl hover:bg-gray-50" @click="mobileOpen = false">Administration</a>
                    {% endif %}
                    {% if is_granted('ROLE_DEPOT_VENTE') %}
                        <a href="{{ path('depot_vente_dashboard') }}" class="block px-3 py-3 rounded-xl hover:bg-amber-50 text-amber-700" @click="mobileOpen = false">Espace dépôt-vente</a>
                    {% endif %}
                    <a href="{{ path('logout', {}) }}" class="block px-3 py-3 rounded-xl hover:bg-red-50 text-red-600" @click="mobileOpen = false">Déconnexion</a>
                {% else %}
                    <a href="{{ path('connexion', {}) }}" class="block px-3 py-3 rounded-xl hover:bg-gray-50 font-medium" @click="mobileOpen = false">Connexion</a>
                    <a href="{{ path('inscription', {}) }}" class="btn-outline block text-center mt-1" @click="mobileOpen = false">S'inscrire</a>
                {% endif %}
            </div>
        </div>
    </div>
</nav>
